---
import { getCollection } from "astro:content";
import { FilterTabs } from "@components/atoms/filter-tabs";
import { PageHeader } from "@components/features/page-header";
import AnimeCard from "@components/features/anime/AnimeCard.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getCollectionAssetUrl, normalizeCollectionEntrySlug } from "@utils/url-utils";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";

// 获取所有追番数据
const animeList = await getCollection("anime");

// 按年份排序
const sortedAnimes = [...animeList].sort((a, b) => {
	const yearA = parseInt(a.data.year);
	const yearB = parseInt(b.data.year);
	return yearB - yearA;
});

// 提取所有唯一的状态
const statuses = new Set<string>(
	animeList.map((anime) => anime.data.status)
);

const getStatusText = (status: string) => {
	const statusMap: Record<string, string> = {
		watching: "追番中",
		completed: "已完成",
		planned: "计划观看",
		dropped: "已弃番",
	};
	return statusMap[status] || status;
};

const getStatusIcon = (status: string) => {
	const iconMap: Record<string, string> = {
		watching: "material-symbols:play-circle",
		completed: "material-symbols:check-circle",
		planned: "material-symbols:schedule",
		dropped: "material-symbols:cancel",
	};
	return iconMap[status] || "material-symbols:movie";
};

// 创建筛选标签
const filterTabs = [
	{
		value: "all",
		label: i18n(I18nKey.friendsFilterAll),
		icon: "material-symbols:apps",
		count: animeList.length,
	},
	...Array.from(statuses).map((status) => ({
		value: status,
		label: getStatusText(status as string),
		icon: getStatusIcon(status as string),
		count: animeList.filter((a) => a.data.status === status).length,
	})),
];

const title = "追番列表";
const subtitle = "我的追番记录，记录每一部值得观看的动画";

function stripMarkdownInline(rawText: string): string {
	return rawText
		.replace(/!\[[^\]]*\]\([^)]*\)/g, "")
		.replace(/\[([^\]]+)\]\([^)]*\)/g, "$1")
		.replace(/[*_`~]/g, "")
		.replace(/<[^>]+>/g, "")
		.trim();
}

function extractAnimeDescription(markdown: string): string {
	const lines = markdown.split(/\r?\n/).map((line) => line.trim());

	for (const line of lines) {
		if (!line) {
			continue;
		}

		if (
			/^#{1,6}\s/.test(line) ||
			/^[-*+]\s/.test(line) ||
			/^\d+\.\s/.test(line) ||
			/^>\s?/.test(line)
		) {
			continue;
		}

		const normalized = stripMarkdownInline(line)
			.replace(/\s+/g, " ")
			.trim();

		if (normalized.length >= 8) {
			return normalized;
		}
	}

	return "点击查看这部番剧的详细记录";
}
---

<MainGridLayout title={title} description={subtitle}>
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>

	<script is:inline src="/js/filter-tabs-handler.js"></script>

	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32 transition-all duration-500 ease-out animate-fadeInUp">
		<div class="card-base z-10 px-6 sm:px-9 py-6 relative w-full">
			<PageHeader title={title} subtitle={subtitle} />

			<div class="mb-8">
				<FilterTabs tabs={filterTabs} dataAttr="status" />
			</div>

			<div id="anime-grid" class="grid grid-cols-2 gap-4 transition-all duration-300 will-change-[grid-template-columns]">
				{
					sortedAnimes.map((anime) => (
						<div data-status={anime.data.status} class="transition-all duration-300 will-change-transform">
							<AnimeCard
								id={normalizeCollectionEntrySlug(anime.id)}
								title={anime.data.title}
								description={extractAnimeDescription(anime.body || "")}
								studio={anime.data.studio}
								cover={getCollectionAssetUrl(anime.data.cover)}
								status={anime.data.status}
								rating={anime.data.rating}
								totalEpisodes={anime.data.totalEpisodes}
								watchedEpisodes={anime.data.watchedEpisodes}
								year={anime.data.year}
								genre={anime.data.genre}
								tags={anime.data.tags}
								link={anime.data.link}
							/>
						</div>
					))
				}
			</div>

			{sortedAnimes.length === 0 && (
				<div class="text-center py-12 animate-fadeInUp">
					<p class="text-slate-500 dark:text-slate-400">📺 开始追番吧...</p>
				</div>
			)}
		</div>
	</div>
</MainGridLayout>

<script define:vars={{ contentLength: animeList.length }}>
	// 自定义筛选逻辑 - 用于状态属性
	document.addEventListener("DOMContentLoaded", () => {
		const filterButtons = document.querySelectorAll("[data-filter-value]");
		const cards = document.querySelectorAll("#anime-grid > div[data-status]");

		filterButtons.forEach((button) => {
			button.addEventListener("click", () => {
				const filterValue = button.getAttribute("data-filter-value");
				const isAll = filterValue === "all";

				cards.forEach((card) => {
					if (isAll) {
						card.style.display = "";
						card.classList.remove("filtered-out");
					} else {
						const status = card.getAttribute("data-status");
						if (status === filterValue) {
							card.style.display = "";
							card.classList.remove("filtered-out");
						} else {
							card.style.display = "none";
							card.classList.add("filtered-out");
						}
					}
				});
			});
		});
	});
</script>

<style>
	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translate3d(0, 24px, 0);
		}
		to {
			opacity: 1;
			transform: translate3d(0, 0, 0);
		}
	}

	:global(.animate-fadeInUp) {
		animation: fadeInUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
		will-change: transform, opacity;
	}

	#anime-grid {
		perspective: 1000px;
	}

	#anime-grid > div.filtered-out {
		opacity: 0;
		pointer-events: none;
		transform: translate3d(0, -10px, 0);
	}
</style>