---
import { Icon } from "astro-icon/components";
import PageHeader from "@components/features/page-header/PageHeader.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";

const title = "记录生活";
const description = "分享생活中的美好时刻";
---

<MainGridLayout title={title} description={description}>
	<div class="prose dark:prose-invert max-w-none">
		<PageHeader 
			title="记录生活" 
			subtitle="用镜头和文字记录生活中的每一个精彩瞬间"
		/>
		
		<div class="grid grid-cols-1 md:grid-cols-2 gap-4 my-8">
			<a href="/anime/" class="block p-6 bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-900 dark:to-blue-800 rounded-lg hover:shadow-lg transition-shadow">
				<div class="flex items-center gap-3 mb-3">
					<Icon name="material-symbols:movie" class="w-8 h-8 text-blue-600 dark:text-blue-300" />
					<h3 class="text-xl font-bold m-0">追番</h3>
				</div>
				<p class="text-sm text-slate-600 dark:text-slate-300 m-0">分享一直在看的动漫</p>
			</a>

			<a href="/diary/" class="block p-6 bg-gradient-to-br from-purple-50 to-purple-100 dark:from-purple-900 dark:to-purple-800 rounded-lg hover:shadow-lg transition-shadow">
				<div class="flex items-center gap-3 mb-3">
					<Icon name="material-symbols:book" class="w-8 h-8 text-purple-600 dark:text-purple-300" />
					<h3 class="text-xl font-bold m-0">日记</h3>
				</div>
				<p class="text-sm text-slate-600 dark:text-slate-300 m-0">记录每日的想法和感受</p>
			</a>

			<a href="/music/" class="block p-6 bg-gradient-to-br from-pink-50 to-pink-100 dark:from-pink-900 dark:to-pink-800 rounded-lg hover:shadow-lg transition-shadow">
				<div class="flex items-center gap-3 mb-3">
					<Icon name="material-symbols:music-note" class="w-8 h-8 text-pink-600 dark:text-pink-300" />
					<h3 class="text-xl font-bold m-0">歌曲</h3>
				</div>
				<p class="text-sm text-slate-600 dark:text-slate-300 m-0">分享最近加入的歌曲</p>
			</a>

			<a href="/sports/" class="block p-6 bg-gradient-to-br from-orange-50 to-orange-100 dark:from-orange-900 dark:to-orange-800 rounded-lg hover:shadow-lg transition-shadow">
				<div class="flex items-center gap-3 mb-3">
					<Icon name="material-symbols:sports-soccer" class="w-8 h-8 text-orange-600 dark:text-orange-300" />
					<h3 class="text-xl font-bold m-0">运动</h3>
				</div>
				<p class="text-sm text-slate-600 dark:text-slate-300 m-0">分享每日运动经历</p>
			</a>

			<a href="/books/" class="block p-6 bg-gradient-to-br from-amber-50 to-amber-100 dark:from-amber-900 dark:to-amber-800 rounded-lg hover:shadow-lg transition-shadow">
				<div class="flex items-center gap-3 mb-3">
					<Icon name="material-symbols:library-books" class="w-8 h-8 text-amber-700 dark:text-amber-300" />
					<h3 class="text-xl font-bold m-0">书籍</h3>
				</div>
				<p class="text-sm text-slate-600 dark:text-slate-300 m-0">分享最近看的书籍</p>
			</a>

			<a href="/projects/" class="block p-6 bg-gradient-to-br from-green-50 to-green-100 dark:from-green-900 dark:to-green-800 rounded-lg hover:shadow-lg transition-shadow">
				<div class="flex items-center gap-3 mb-3">
					<Icon name="material-symbols:work" class="w-8 h-8 text-green-600 dark:text-green-300" />
					<h3 class="text-xl font-bold m-0">项目</h3>
				</div>
				<p class="text-sm text-slate-600 dark:text-slate-300 m-0">分享我写过的各种项目</p>
			</a>

			<a href="/websites/" class="block p-6 bg-gradient-to-br from-cyan-50 to-cyan-100 dark:from-cyan-900 dark:to-cyan-800 rounded-lg hover:shadow-lg transition-shadow">
				<div class="flex items-center gap-3 mb-3">
					<Icon name="material-symbols:language" class="w-8 h-8 text-cyan-600 dark:text-cyan-300" />
					<h3 class="text-xl font-bold m-0">网站</h3>
				</div>
				<p class="text-sm text-slate-600 dark:text-slate-300 m-0">分享实用的网站</p>
			</a>
		</div>
	</div>
</MainGridLayout>
