---
import { getCollection, render } from "astro:content";
import MainGridLayout from "../../layouts/MainGridLayout.astro";
import { PageHeader } from "../../components/features/page-header";
import Markdown from "../../components/misc/Markdown.astro";
import Comment from "../../components/comment/index.astro";
import { Icon } from "astro-icon/components";
import { getCollectionAssetUrl, normalizeCollectionEntrySlug } from "../../utils/url-utils";

export async function getStaticPaths() {
	const songs = await getCollection("songs");
	return songs.map((entry) => ({
		params: { slug: normalizeCollectionEntrySlug(entry.id) },
		props: { entry },
	}));
}

interface Props {
	entry: any;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, artist, album, cover, link, rating, tags } = entry.data;
const entrySlug = normalizeCollectionEntrySlug(entry.id);
const coverUrl = getCollectionAssetUrl(cover);
const fullTitle = `${title} - ${artist}`;
---

<MainGridLayout title={fullTitle} description={album}>
	<script>
		import("../../scripts/right-sidebar-layout.js");
	</script>

	<!-- 主容器 - 白色圆角背景 -->
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32 transition-all duration-500 ease-out animate-fadeInUp">
		<div class="card-base z-10 px-9 py-6 relative w-full">
			<!-- 页面头部 -->
			<PageHeader title={title} subtitle={artist} />

			<!-- 封面和元数据 -->
			{coverUrl && (
				<div class="my-6 flex gap-6 items-start">
					<div class="shrink-0">
						<img
							src={coverUrl}
							alt={title}
							class="w-32 h-32 rounded-lg object-cover shadow-lg"
							loading="lazy"
						/>
					</div>
					<div class="flex-1">
						<div class="mb-4">
							<p class="text-sm text-black/50 dark:text-white/50 mb-1">专辑</p>
							<p class="text-base text-black/80 dark:text-white/80">{album}</p>
						</div>
						{rating && (
							<div class="mb-4 flex items-center gap-2">
								<p class="text-sm text-black/50 dark:text-white/50">评分</p>
								<div class="flex items-center gap-1">
									{[...Array(5)].map((_, i) => (
										<Icon
											name="material-symbols:star-rounded"
											class={`w-4 h-4 ${i < Math.floor(rating) ? "text-yellow-500" : "text-black/20 dark:text-white/20"}`}
										/>
									))}
									<span class="ml-2 text-sm font-medium">{rating}/5</span>
								</div>
							</div>
						)}
						{tags && tags.length > 0 && (
							<div>
								<p class="text-sm text-black/50 dark:text-white/50 mb-2">标签</p>
								<div class="flex flex-wrap gap-2">
									{tags.map((tag: string) => (
										<span class="px-2.5 py-1 text-xs rounded-full bg-purple-500/10 text-purple-600 dark:text-purple-400 font-medium">
											{tag}
										</span>
									))}
								</div>
							</div>
						)}
					</div>
				</div>
			)}

			<!-- Markdown内容 -->
			<Markdown class="mt-8">
				<Content />
			</Markdown>

			<!-- 外部链接按钮 -->
			{link && (
				<div class="mt-8 pt-6 border-t border-black/10 dark:border-white/10">
					<a
						href={link}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-2 px-4 py-2 rounded-lg font-medium bg-purple-500/10 text-purple-600 dark:text-purple-400 hover:bg-purple-500/20 transition-colors duration-200"
					>
						<Icon name="material-symbols:open-in-new" class="w-4 h-4" />
						在线播放
					</a>
				</div>
			)}
		</div>
	</div>

	<!-- 评论区域 -->
	<div class="mt-4 transition-all duration-500 ease-out animate-fadeInUp" style="animation-delay: 0.1s;">
		<Comment path={`/music/${entrySlug}/`} />
	</div>
</MainGridLayout>

<style>
	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(24px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	:global(.animate-fadeInUp) {
		animation: fadeInUp 0.5s ease-out forwards;
	}
</style>
