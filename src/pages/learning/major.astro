---
import "@styles/learning-pages.css";
import PageHeader from "@components/features/page-header/PageHeader.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import { removeFileExtension } from "@utils/url-utils";

const title = "考研专业课";
const description = "专业课学习记录";

// 获取所有帖子并筛选分类为 'major' 的
const allPosts = await getCollection("posts");
const majorPosts = allPosts
	.filter((post) => post.data.category === "major" && !post.data.draft)
	.sort((a, b) => new Date(b.data.published).getTime() - new Date(a.data.published).getTime());
---

<MainGridLayout title={title} description={description}>
	<div class="learning-container">
		<div class="learning-content-base">
			<PageHeader title="考研专业课" subtitle="记录专业课学习内容" />

			{majorPosts.length > 0 ? (
				<div>
					{majorPosts.map((post) => (
						<a href={`/posts/${removeFileExtension(post.id)}/`} class="learning-post-item block">
							<h3 class="learning-post-title text-purple-600 dark:text-purple-300">
								{post.data.title}
							</h3>
							<p class="learning-post-description">
								{post.data.description}
							</p>
							<div class="learning-post-meta">
								<span>{new Date(post.data.published).toLocaleDateString('zh-CN')}</span>
								{post.data.tags.length > 0 && (
									<div class="flex gap-2">
										{post.data.tags.slice(0, 3).map((tag) => (
											<span class="bg-purple-100 dark:bg-purple-900 px-2 py-1 rounded text-xs">
												{tag}
											</span>
										))}
									</div>
								)}
							</div>
						</a>
					))}
				</div>
			) : (
				<div class="learning-empty-state">
					<p class="learning-empty-message">
						📖 开始记录你的专业课学习...
					</p>
				</div>
			)}
		</div>
	</div>
</MainGridLayout>
