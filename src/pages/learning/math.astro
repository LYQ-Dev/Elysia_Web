---
import { Icon } from "astro-icon/components";
import PageHeader from "@components/features/page-header/PageHeader.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import { removeFileExtension } from "@utils/url-utils";

const title = "考研数学";
const description = "备战考研数学的学习记录";

// 获取所有帖子并筛选分类为 'math' 的
const allPosts = await getCollection("posts");
const mathPosts = allPosts
	.filter((post) => post.data.category === "math" && !post.data.draft)
	.sort((a, b) => new Date(b.data.published).getTime() - new Date(a.data.published).getTime());
---

<MainGridLayout title={title} description={description}>
	<div class="prose dark:prose-invert max-w-none">
		<PageHeader title="考研数学" subtitle="记录数学备考的学习过程" />
		
		<div class="bg-slate-100 dark:bg-slate-800 rounded-lg p-6 mb-6">
			<div class="flex items-center gap-3 mb-4">
				<Icon name="material-symbols:calculate" class="w-8 h-8 text-blue-500" />
				<h2 class="text-2xl font-bold m-0">数学学习记录</h2>
			</div>
			<p class="text-slate-600 dark:text-slate-400">
				这里记录考研数学的学习内容、做题笔记和复习进度。
			</p>
		</div>

		{mathPosts.length > 0 ? (
			<div class="space-y-4 mt-8">
				{mathPosts.map((post) => (
					<a href={`/posts/${removeFileExtension(post.id)}/`} class="card-base block p-6 hover:shadow-lg transition-shadow">
						<h3 class="text-xl font-bold mb-2 text-blue-600 dark:text-blue-300">
							{post.data.title}
						</h3>
						<p class="text-slate-600 dark:text-slate-400 mb-3">
							{post.data.description}
						</p>
						<div class="flex items-center justify-between text-sm text-slate-500 dark:text-slate-400">
							<span>{new Date(post.data.published).toLocaleDateString('zh-CN')}</span>
							{post.data.tags.length > 0 && (
								<div class="flex gap-2">
									{post.data.tags.slice(0, 3).map((tag) => (
										<span class="bg-blue-100 dark:bg-blue-900 px-2 py-1 rounded text-xs">
											{tag}
										</span>
									))}
								</div>
							)}
						</div>
					</a>
				))}
			</div>
		) : (
			<div class="mt-8">
				<p class="text-center text-slate-500 dark:text-slate-400">
					📚 开始记录你的数学学习之旅...
				</p>
			</div>
		)}
	</div>
</MainGridLayout>
