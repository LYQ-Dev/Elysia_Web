---
import { Icon } from "astro-icon/components";
import PageHeader from "@components/features/page-header/PageHeader.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";

const title = "考研英语";
const description = "英语学习记录";
---

<MainGridLayout title={title} description={description}>
	<div class="prose dark:prose-invert max-w-none">
		<PageHeader title="考研英语" subtitle="记录英语备考的学习过程" />
		
		<div class="bg-slate-100 dark:bg-slate-800 rounded-lg p-6 mb-6">
			<div class="flex items-center gap-3 mb-4">
				<Icon name="material-symbols:language" class="w-8 h-8 text-green-500" />
				<h2 class="text-2xl font-bold m-0">英语学习记录</h2>
			</div>
			<p class="text-slate-600 dark:text-slate-400">
				记录英语单词、阅读理解、完形填空等学习内容和备考心得。
			</p>
		</div>

		<div class="mt-8">
			<p class="text-center text-slate-500 dark:text-slate-400">
				🌐 开始你的英语学习之旅...
			</p>
		</div>
	</div>
</MainGridLayout>
