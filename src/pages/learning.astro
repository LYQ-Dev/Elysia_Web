---
import { Icon } from "astro-icon/components";
import PageHeader from "@components/features/page-header/PageHeader.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";

const title = "记录学习";
const description = "备战考研的学习记录";
---

<MainGridLayout title={title} description={description}>
	<div class="prose dark:prose-invert max-w-none">
		<PageHeader 
			title="记录学习" 
			subtitle="记录考研之路上的每一步进展"
		/>
		
		<div class="grid grid-cols-1 md:grid-cols-2 gap-4 my-8">
			<a href="/learning/math/" class="block p-6 bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-900 dark:to-blue-800 rounded-lg hover:shadow-lg transition-shadow">
				<div class="flex items-center gap-3 mb-3">
					<Icon name="material-symbols:calculate" class="w-8 h-8 text-blue-600 dark:text-blue-300" />
					<h3 class="text-xl font-bold m-0">数学</h3>
				</div>
				<p class="text-sm text-slate-600 dark:text-slate-300 m-0">每天备战考研的数学经历</p>
			</a>

			<a href="/learning/major/" class="block p-6 bg-gradient-to-br from-purple-50 to-purple-100 dark:from-purple-900 dark:to-purple-800 rounded-lg hover:shadow-lg transition-shadow">
				<div class="flex items-center gap-3 mb-3">
				<Icon name="material-symbols:notes" class="w-8 h-8 text-purple-600 dark:text-purple-300" />
					<h3 class="text-xl font-bold m-0">专业课</h3>
				</div>
				<p class="text-sm text-slate-600 dark:text-slate-300 m-0">专业课学习进度和笔记</p>
			</a>

			<a href="/learning/english/" class="block p-6 bg-gradient-to-br from-green-50 to-green-100 dark:from-green-900 dark:to-green-800 rounded-lg hover:shadow-lg transition-shadow">
				<div class="flex items-center gap-3 mb-3">
					<Icon name="material-symbols:language" class="w-8 h-8 text-green-600 dark:text-green-300" />
					<h3 class="text-xl font-bold m-0">英语</h3>
				</div>
				<p class="text-sm text-slate-600 dark:text-slate-300 m-0">考研英语复习计划</p>
			</a>

			<a href="/learning/exam/" class="block p-6 bg-gradient-to-br from-red-50 to-red-100 dark:from-red-900 dark:to-red-800 rounded-lg hover:shadow-lg transition-shadow">
				<div class="flex items-center gap-3 mb-3">
					<Icon name="material-symbols:school-outline" class="w-8 h-8 text-red-600 dark:text-red-300" />
					<h3 class="text-xl font-bold m-0">考研择校</h3>
				</div>
				<p class="text-sm text-slate-600 dark:text-slate-300 m-0">院校信息搜集和分析</p>
			</a>
		</div>

		<div class="bg-blue-50 dark:bg-blue-900 border-l-4 border-blue-500 p-6 rounded mt-8">
			<div class="flex gap-3">
				<Icon name="material-symbols:info" class="w-6 h-6 text-blue-600 dark:text-blue-300 flex-shrink-0 mt-1" />
				<div>
					<h4 class="font-bold text-blue-900 dark:text-blue-100 m-0 mb-2">学习建议</h4>
					<p class="text-blue-800 dark:text-blue-200 text-sm m-0">
						制定合理的学习计划，坚持每天的复习，记录学习心得，定期回顾和总结是成功的关键。加油！
					</p>
				</div>
			</div>
		</div>
	</div>
</MainGridLayout>
