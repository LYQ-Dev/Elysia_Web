---
import { getCollection } from "astro:content";
import { FilterTabs } from "@components/atoms/filter-tabs";
import { PageHeader } from "@components/features/page-header";
import { ProjectCard } from "@components/features/projects";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";

import { siteConfig } from "../config";
import { UNCATEGORIZED } from "../constants/constants";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";

if (!siteConfig.featurePages.projects) {
	return Astro.redirect("/404/");
}

// 获取所有项目
const projects = await getCollection("projects");

// 按开始日期排序（最新优先）
const sortedProjects = [...projects].sort((a, b) => {
	const dateA = new Date(a.data.startDate).getTime();
	const dateB = new Date(b.data.startDate).getTime();
	return dateB - dateA;
});

// 获取所有分类
const categories = [
	...new Set(sortedProjects.map((project) => project.data.category)),
];

const getCategoryText = (category: string) => {
	switch (category) {
		case "web":
			return i18n(I18nKey.projectsWeb);
		case "mobile":
			return i18n(I18nKey.projectsMobile);
		case "desktop":
			return i18n(I18nKey.projectsDesktop);
		case "other":
			return i18n(I18nKey.projectsOther);
		case UNCATEGORIZED:
			return i18n(I18nKey.uncategorized);
		default:
			return category;
	}
};

const getCategoryIcon = (category: string) => {
	switch (category) {
		case "web":
			return "material-symbols:language";
		case "mobile":
			return "material-symbols:smartphone";
		case "desktop":
			return "material-symbols:desktop-windows";
		case "other":
			return "material-symbols:widgets";
		default:
			return "material-symbols:folder";
	}
};

const filterTabs = [
	{
		value: "all",
		label: i18n(I18nKey.friendsFilterAll),
		icon: "material-symbols:apps",
		count: sortedProjects.length,
	},
	...categories.map((category) => ({
		value: category,
		label: getCategoryText(category),
		icon: getCategoryIcon(category),
		count: sortedProjects.filter((p) => p.data.category === category).length,
	})),
];

const title = i18n(I18nKey.projects);
const subtitle = i18n(I18nKey.projectsSubtitle);
---

<MainGridLayout title={title} description={subtitle}>
	<script>
		import("../scripts/right-sidebar-layout.js");
		import { loadIconify } from "../utils/icon-loader";

		loadIconify().catch((error) => {
			console.error("Failed to load Iconify:", error);
		});
	</script>

	<script is:inline src="/js/filter-tabs-handler.js"></script>

	<div
		class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32"
	>
		<div class="card-base z-10 px-6 sm:px-9 py-6 relative w-full">
			<PageHeader title={title} subtitle={subtitle} />

			<div class="mb-8">
				<FilterTabs tabs={filterTabs} dataAttr="category" />
			</div>

			<div
				id="projects-grid"
				class="grid grid-cols-1 md:grid-cols-2 gap-4 items-start"
			>
				{
					sortedProjects.map((project) => (
						<div data-category={project.data.category}>
							<ProjectCard
								project={{
									id: project.id,
									title: project.data.title,
									description: project.data.description,
									image: project.data.image || "",
									category: project.data.category,
									techStack: project.data.techStack,
									status: project.data.status,
									liveDemo: project.data.liveDemo,
									sourceCode: project.data.sourceCode,
									visitUrl: project.data.visitUrl,
									startDate: new Date(project.data.startDate).toISOString().split('T')[0],
									endDate: project.data.endDate ? new Date(project.data.endDate).toISOString().split('T')[0] : undefined,
									featured: project.data.featured || false,
									tags: project.data.tags || [],
									showImage: true,
								}}
								maxTechStack={4}
							/>
						</div>
					))
				}
			</div>

			<div id="no-results" class="hidden text-center py-16">
				<Icon
					name="material-symbols:search-off-rounded"
					class="text-6xl text-black/15 dark:text-white/15 mb-4"
				/>
				<p class="text-black/40 dark:text-white/40 text-lg">
					No matching projects
				</p>
			</div>
		</div>
	</div>
</MainGridLayout>

<script define:vars={{ contentLength: sortedProjects.length }}>
	// 自定义筛选逻辑 - 用于分类属性
	document.addEventListener("DOMContentLoaded", () => {
		const filterButtons = document.querySelectorAll("[data-filter-value]");
		const cards = document.querySelectorAll("#projects-grid > div[data-category]");

		filterButtons.forEach((button) => {
			button.addEventListener("click", () => {
				const filterValue = button.getAttribute("data-filter-value");
				const isAll = filterValue === "all";

				cards.forEach((card) => {
					if (isAll) {
						card.style.display = "";
						card.classList.remove("filtered-out");
					} else {
						const category = card.getAttribute("data-category");
						if (category === filterValue) {
							card.style.display = "";
							card.classList.remove("filtered-out");
						} else {
							card.style.display = "none";
							card.classList.add("filtered-out");
						}
					}
				});
			});
		});
	});
</script>
