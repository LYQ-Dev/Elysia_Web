---
import { getCollection, render } from "astro:content";
import MainGridLayout from "../../layouts/MainGridLayout.astro";
import { PageHeader } from "../../components/features/page-header";
import Markdown from "../../components/misc/Markdown.astro";
import Comment from "../../components/comment/index.astro";
import { Icon } from "astro-icon/components";

export async function getStaticPaths() {
	const animeList = await getCollection("anime");
	return animeList.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

interface Props {
	entry: any;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, studio, cover, status, rating, totalEpisodes, watchedEpisodes = 0, year, genre = [], tags = [], link, airDate } = entry.data;

const getStatusInfo = (status: string) => {
	const statusMap: Record<string, { text: string; color: string; icon: string }> = {
		watching: { text: "追番中", color: "blue", icon: "material-symbols:play-circle" },
		completed: { text: "已完成", color: "green", icon: "material-symbols:check-circle" },
		planned: { text: "计划观看", color: "amber", icon: "material-symbols:schedule" },
		dropped: { text: "已弃番", color: "gray", icon: "material-symbols:cancel" },
	};
	return statusMap[status] || { text: status, color: "gray", icon: "material-symbols:play-circle" };
};

const statusInfo = getStatusInfo(status);
const colorMap: Record<string, string> = {
	blue: "bg-blue-500/10 text-blue-600 dark:text-blue-400 border-blue-600/20 dark:border-blue-400/20",
	green: "bg-green-500/10 text-green-600 dark:text-green-400 border-green-600/20 dark:border-green-400/20",
	amber: "bg-amber-500/10 text-amber-600 dark:text-amber-400 border-amber-600/20 dark:border-amber-400/20",
	gray: "bg-gray-500/10 text-gray-600 dark:text-gray-400 border-gray-600/20 dark:border-gray-400/20",
};

// 主题色映射（用于进度条）
const themeColorMap: Record<string, string> = {
	watching: "from-blue-500 to-blue-600",
	completed: "from-green-500 to-green-600",
	planned: "from-amber-500 to-amber-600",
	dropped: "from-gray-500 to-gray-600",
};

const watchProgress = totalEpisodes > 0 ? (watchedEpisodes / totalEpisodes * 100) : 0;
---

<MainGridLayout title={title} description={studio}>
	<script>
		import("../../scripts/right-sidebar-layout.js");
	</script>

	<!-- 主容器 - 白色圆角背景 -->
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32 transition-all duration-500 ease-out animate-fadeInUp">
		<div class="card-base z-10 px-9 py-6 relative w-full">
			<!-- 页面头部 -->
			<PageHeader title={title} subtitle={studio} />

			<!-- 封面和元数据 -->
			{cover && (
				<div class="my-6 flex gap-6 items-start">
					<div class="shrink-0">
						<img
							src={cover}
							alt={title}
							class="w-32 h-48 rounded-lg object-cover shadow-lg"
							loading="lazy"
						/>
					</div>
					<div class="flex-1">
						<div class="mb-4">
							<p class="text-sm text-black/50 dark:text-white/50 mb-1">制作工作室</p>
							<p class="text-base text-black/80 dark:text-white/80">{studio}</p>
						</div>
						<div class="mb-4">
							<p class="text-sm text-black/50 dark:text-white/50 mb-1">放映年份</p>
							<p class="text-base text-black/80 dark:text-white/80">{year}</p>
						</div>
						{airDate && (
							<div class="mb-4">
								<p class="text-sm text-black/50 dark:text-white/50 mb-1">播出日期</p>
								<p class="text-base text-black/80 dark:text-white/80">{airDate}</p>
							</div>
						)}
						{rating && (
							<div class="mb-4 flex items-center gap-2">
								<p class="text-sm text-black/50 dark:text-white/50">评分</p>
								<div class="flex items-center gap-1">
									{[...Array(5)].map((_, i) => (
										<Icon
											name="material-symbols:star-rounded"
											class={`w-4 h-4 ${i < Math.floor(rating) ? "text-yellow-500" : "text-black/20 dark:text-white/20"}`}
										/>
									))}
									<span class="ml-2 text-sm font-medium">{rating}/5</span>
								</div>
							</div>
						)}
						<div class="mb-4 flex items-center gap-2">
							<p class="text-sm text-black/50 dark:text-white/50">观看状态</p>
							<span class={`px-3 py-1.5 rounded-full text-sm font-medium flex items-center gap-2 border ${colorMap[statusInfo.color]}`}>
								<Icon name={statusInfo.icon} class="w-4 h-4" />
								{statusInfo.text}
							</span>
						</div>
						{totalEpisodes > 0 && (
							<div class="mb-4">
								<p class="text-sm text-black/50 dark:text-white/50 mb-2">观看进度</p>
								<div class="flex items-center gap-3">
									<div class="flex-1 h-2.5 rounded-full bg-black/10 dark:bg-white/10 overflow-hidden">
										<div
											class={`h-full rounded-full bg-gradient-to-r ${themeColorMap[status]} transition-all duration-300 will-change-transform`}
											style={`width: ${watchProgress}%; transition-property: width; transition-duration: 300ms; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);`}
										/>
									</div>
									<span class="text-sm text-black/80 dark:text-white/80 whitespace-nowrap font-semibold">
										{watchedEpisodes}/{totalEpisodes}
									</span>
								</div>
							</div>
						)}
					</div>
				</div>
			)}

			<!-- 分类和标签 -->
			{genre && genre.length > 0 && (
				<div class="mb-4">
					<p class="text-sm text-black/50 dark:text-white/50 mb-2 font-medium">分类</p>
					<div class="flex flex-wrap gap-2">
						{genre.map((g: string) => (
							<span class="px-3 py-1 text-sm rounded-full bg-red-500/10 text-red-600 dark:text-red-400 font-medium">
								{g}
							</span>
						))}
					</div>
				</div>
			)}

			{tags && tags.length > 0 && (
				<div class="mb-6">
					<p class="text-sm text-black/50 dark:text-white/50 mb-2 font-medium">标签</p>
					<div class="flex flex-wrap gap-2">
						{tags.map((tag: string) => (
							<span class="px-3 py-1 text-xs rounded-full bg-pink-500/10 text-pink-600 dark:text-pink-400 font-medium">
								{tag}
							</span>
						))}
					</div>
				</div>
			)}

			<!-- Markdown内容 -->
			<Markdown class="mt-8 pt-6 border-t border-black/10 dark:border-white/10">
				<Content />
			</Markdown>

			<!-- 外部链接按钮 -->
			{link && (
				<div class="mt-8 pt-6 border-t border-black/10 dark:border-white/10">
					<a
						href={link}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-2 px-4 py-2 rounded-lg font-medium bg-red-500/10 text-red-600 dark:text-red-400 hover:bg-red-500/20 transition-colors duration-200"
					>
						<Icon name="material-symbols:open-in-new" class="w-4 h-4" />
						查看详情
					</a>
				</div>
			)}
		</div>
	</div>

	<!-- 评论区域 -->
	<div class="mt-4 transition-all duration-500 ease-out animate-fadeInUp" style="animation-delay: 0.1s;">
		<Comment path={`/anime/${entry.id}/`} />
	</div>
</MainGridLayout>

<style>
	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translate3d(0, 24px, 0);
		}
		to {
			opacity: 1;
			transform: translate3d(0, 0, 0);
		}
	}

	:global(.animate-fadeInUp) {
		animation: fadeInUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
		will-change: transform, opacity;
	}
</style>
