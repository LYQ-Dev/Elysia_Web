---
/**
 * Banner 组件
 * 支持单图模式和轮播图模式，包含文字覆盖层和水波纹效果
 * 轮播模式使用 Ken Burns + Crossfade 动画（参考 Firefly 实现）
 */

import TypewriterText from "@components/atoms/typewriter-text/TypewriterText.astro";
import Image from "@components/atoms/Image/Image.astro";
import { Icon } from "astro-icon/components";
import { siteConfig } from "../../config";
import { BANNER_HEIGHT_EXTEND } from "../../constants/constants";

interface Props {
	// Banner 配置
	bannerImages: {
		desktop: string | string[];
		mobile: string | string[];
	};

	// 响应式
	mobileNonHomeBannerClass?: string;

	// 文字覆盖层
	showTextOverlay?: boolean;
	overlayTitle?: string;
	overlaySubtitle?: string | string[];
	typewriter?: boolean;

	// 水波纹效果
	showWave?: boolean;
}

const {
	bannerImages,
	mobileNonHomeBannerClass = "",
	showTextOverlay = false,
	overlayTitle = siteConfig.banner.homeText?.title,
	overlaySubtitle = siteConfig.banner.homeText?.subtitle,
	typewriter = siteConfig.banner.homeText?.typewriter?.enable ?? false,
	showWave = siteConfig.banner.waves?.enable ?? true,
} = Astro.props;

// 标准化图片数组
const normalizeToArray = (images: string | string[]): string[] =>
	Array.isArray(images) ? images : [images];

const desktopImages = normalizeToArray(bannerImages.desktop).filter(Boolean);
const mobileImages = normalizeToArray(bannerImages.mobile).filter(Boolean);

const isCarouselEnabled =
	siteConfig.banner.carousel?.enable &&
	(desktopImages.length > 1 || mobileImages.length > 1);

// 轮播间隔最小 1.5 秒，防止 setInterval 卡顿
const carouselIntervalMs = Math.max(
	(siteConfig.banner.carousel?.interval || 6) * 1000,
	1500,
);

// 淡入淡出时间：间隔的 40%，范围 500ms ~ 1500ms
const fadeMs = Math.min(Math.max(Math.round(carouselIntervalMs * 0.4), 500), 1500);

// Ken Burns 动画时长 = 间隔 + 淡入，确保旧图在 crossfade 期间仍在运动，消除停顿感
const kbDurationMs = carouselIntervalMs + fadeMs;

const hasBannerCredit = siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;
const trackerCells = Array.from({ length: 25 }, (_, index) => index + 1);
---

<div
	id="banner-wrapper"
	class={`absolute z-10 w-full transition duration-700 overflow-hidden ${mobileNonHomeBannerClass}`}
	style={`top: -${BANNER_HEIGHT_EXTEND}vh`}
>
	<div class="banner-tilt-container">
		<div class="banner-tilt-canvas canvas" aria-hidden="true">
			{trackerCells.map((cellIndex) => (
				<span class={`banner-tracker tracker tr-${cellIndex}`} />
			))}
		</div>

		<div
			class:list={[
				"banner-tilt-panel",
				{ "with-attached-fade": showWave },
			]}
		>
			{isCarouselEnabled ? (
				/* 轮播图模式：Ken Burns + Crossfade */
				<div
					id="banner-carousel"
					class="relative h-full w-full"
					data-mobile-count={mobileImages.length}
					data-desktop-count={desktopImages.length}
					data-carousel-interval={carouselIntervalMs}
					data-fade-ms={fadeMs}
				>
					{/* 移动端：第一张图直接渲染，其余放入 template 延迟加载 */}
					{mobileImages.length > 0 && (
						<div class="banner-image-slot-mobile absolute inset-0 block md:hidden">
							<Image
								alt="Mobile banner image 1"
								class="object-cover h-full w-full"
								src={mobileImages[0]}
								position={siteConfig.banner.position}
								widths={[640, 1024, 1536]}
								sizes="100vw"
								loading="eager"
								fetchpriority="high"
							/>
						</div>
					)}
					{mobileImages.slice(1).map((src, i) => (
						<template class="banner-tpl-mobile">
							<Image
								alt={`Mobile banner image ${i + 2}`}
								class="object-cover h-full w-full"
								src={src}
								position={siteConfig.banner.position}
								widths={[640, 1024, 1536]}
								sizes="100vw"
								loading="lazy"
								fetchpriority="low"
							/>
						</template>
					))}

					{/* 桌面端：第一张图直接渲染，其余放入 template 延迟加载 */}
					{desktopImages.length > 0 && (
						<div class="banner-image-slot-desktop absolute inset-0 hidden md:block">
							<Image
								id="banner"
								alt="Desktop banner image 1"
								class="object-cover h-full w-full"
								src={desktopImages[0]}
								position={siteConfig.banner.position}
								widths={[1024, 1536, 2048, 2560]}
								sizes="100vw"
								loading="eager"
								fetchpriority="high"
							/>
						</div>
					)}
					{desktopImages.slice(1).map((src, i) => (
						<template class="banner-tpl-desktop">
							<Image
								alt={`Desktop banner image ${i + 2}`}
								class="object-cover h-full w-full"
								src={src}
								position={siteConfig.banner.position}
								widths={[1024, 1536, 2048, 2560]}
								sizes="100vw"
								loading="lazy"
								fetchpriority="low"
							/>
						</template>
					))}
				</div>
			) : (
				/* 单图模式 */
				<div id="banner-single-container" class="relative h-full w-full">
					<script
						is:inline
						define:vars={{
							desktopImages: bannerImages.desktop,
							mobileImages: bannerImages.mobile,
							position: siteConfig.banner.position,
						}}
					>
						(function () {
							const getRandomImage = (images, storageKey) => {
								if (Array.isArray(images)) {
									if (images.length === 0) {return null;}
									if (images.length === 1) {return images[0];}

									const lastIndex = sessionStorage.getItem(storageKey);
									let newIndex;

									do {
										newIndex = Math.floor(Math.random() * images.length);
									} while (newIndex === parseInt(lastIndex || "-1"));

									sessionStorage.setItem(storageKey, newIndex.toString());
									return images[newIndex];
								}
								return images || null;
							};

							const getWebpFallbackCandidates = (src) => {
								if (!src || !/\.webp(\?.*)?$/i.test(src)) {
									return [];
								}
								return [
									src.replace(/\.webp(\?.*)?$/i, ".jpg$1"),
									src.replace(/\.webp(\?.*)?$/i, ".jpeg$1"),
									src.replace(/\.webp(\?.*)?$/i, ".png$1"),
								];
							};

							const attachWebpFallback = (img, sourcePath) => {
								const candidates = getWebpFallbackCandidates(sourcePath);
								if (candidates.length === 0) {
									return;
								}
								let index = 0;
								const onError = () => {
									if (index < candidates.length) {
										img.src = candidates[index++];
										return;
									}
									img.removeEventListener("error", onError);
									img.classList.add("banner-image-unavailable");
								};
								img.addEventListener("error", onError);
							};

							const container = document.getElementById("banner-single-container");

							// 检查容器是否已有图片，避免在页面切换或缩放时重复创建
							if (container.querySelector("img")) {
								return;
							}

							const desktopSrc = getRandomImage(desktopImages, "banner_desktop_index");
							const mobileSrc = getRandomImage(mobileImages, "banner_mobile_index");

							if (mobileSrc) {
								const mobileImg = document.createElement("img");
								mobileImg.alt = "Mobile banner image of the blog";
								mobileImg.className =
									"block md:hidden object-cover h-full w-full transition duration-700 opacity-100";
								mobileImg.src = mobileSrc;
								attachWebpFallback(mobileImg, mobileSrc);
								mobileImg.loading = "eager";
								mobileImg.fetchPriority = "high";
								mobileImg.dataset.position = position;
								container.appendChild(mobileImg);
							}

							if (desktopSrc) {
								const desktopImg = document.createElement("img");
								desktopImg.id = "banner";
								desktopImg.alt = "Desktop banner image of the blog";
								desktopImg.className =
									"hidden md:block object-cover h-full w-full transition duration-700 opacity-100";
								desktopImg.src = desktopSrc;
								attachWebpFallback(desktopImg, desktopSrc);
								desktopImg.loading = "eager";
								desktopImg.fetchPriority = "high";
								desktopImg.dataset.position = position;
								container.appendChild(desktopImg);
							}
						})();
					</script>
				</div>
			)}

			<!-- 贴合图片底边的遮线条：随图片层一起倾斜移动 -->
			<span class="banner-bottom-solid-strip-attached" aria-hidden="true" />
		</div>
	</div>

	<!-- Ken Burns 动画样式（放在 body 中，不受 Swup head 替换影响） -->
	{isCarouselEnabled && (
		<Fragment set:html={`<style>
			@keyframes bannerKenBurns {
				0% { transform: scale(1.03); }
				100% { transform: scale(1.13); }
			}
			.banner-kb {
				animation: bannerKenBurns ${kbDurationMs}ms ease-out forwards;
			}
		</style>`} />
	)}

	<!-- 轮播脚本：随机起始 + 帧收集 + Ken Burns + Crossfade + 触摸/鼠标事件 -->
	{isCarouselEnabled && (
		<script is:inline data-swup-ignore-script>
			(function initBannerCarousel() {
				var container = document.getElementById('banner-carousel');
				if (!container) return;

				var mobileCount = parseInt(container.dataset.mobileCount || '0', 10);
				var desktopCount = parseInt(container.dataset.desktopCount || '0', 10);
				var interval = parseInt(container.dataset.carouselInterval || '6000', 10);
				var FADE_MS = parseInt(container.dataset.fadeMs || '1500', 10);

				if (mobileCount <= 1 && desktopCount <= 1) return;

				var preloadedSources = new Set();

				function getWebpFallbackCandidates(src) {
					if (!src || !/\.webp(\?.*)?$/i.test(src)) return [];
					return [
						src.replace(/\.webp(\?.*)?$/i, '.jpg$1'),
						src.replace(/\.webp(\?.*)?$/i, '.jpeg$1'),
						src.replace(/\.webp(\?.*)?$/i, '.png$1')
					];
				}

				function installWebpFallback(img) {
					if (!img || img.dataset.webpFallbackBound === '1') return;
					var candidates = getWebpFallbackCandidates(img.getAttribute('src') || '');
					if (!candidates.length) return;

					var index = 0;
					var onError = function () {
						if (index < candidates.length) {
							img.src = candidates[index++];
							return;
						}
						img.removeEventListener('error', onError);
						img.classList.add('banner-image-unavailable');
					};

					img.dataset.webpFallbackBound = '1';
					img.addEventListener('error', onError);
				}

				function bindFallbackInNode(node) {
					if (!node || !node.querySelectorAll) return;
					var images = node.querySelectorAll('img');
					for (var i = 0; i < images.length; i++) {
						installWebpFallback(images[i]);
					}
				}

				// 清理上一次 Swup 导航遗留的监听器和定时器
				if (window.__bannerCarouselCleanup) {
					window.__bannerCarouselCleanup();
					window.__bannerCarouselCleanup = null;
				}

				// 保存初始帧 HTML，供帧收集使用
				if (typeof window.__bannerInitialFrameHtml === 'undefined') {
					window.__bannerInitialFrameHtml = {};
				}

				function rememberInitialFrame(slotClass) {
					var slot = container.querySelector('.' + slotClass);
					if (!slot) return;
					if (!window.__bannerInitialFrameHtml[slotClass]) {
						window.__bannerInitialFrameHtml[slotClass] = slot.innerHTML;
					}
				}

				rememberInitialFrame('banner-image-slot-mobile');
				rememberInitialFrame('banner-image-slot-desktop');

				// 随机起始索引（Swup 导航间保留，F5 刷新重置）
				if (typeof window.__bannerRandomIndex === 'undefined') {
					window.__bannerRandomIndex = {
						mobile: mobileCount > 1 ? Math.floor(Math.random() * mobileCount) : 0,
						desktop: desktopCount > 1 ? Math.floor(Math.random() * desktopCount) : 0
					};
				}

				// 从 template 替换默认图片
				function applyRandom(slotClass, tplClass, randomIndex) {
					if (randomIndex === 0) return;
					var slot = container.querySelector('.' + slotClass);
					var templates = container.querySelectorAll('.' + tplClass);
					if (!slot || !templates.length) return;
					var tpl = templates[randomIndex - 1];
					if (!tpl) return;
					slot.innerHTML = '';
					slot.appendChild(tpl.content.cloneNode(true));
					bindFallbackInNode(slot);
				}

				applyRandom('banner-image-slot-mobile', 'banner-tpl-mobile', window.__bannerRandomIndex.mobile);
				applyRandom('banner-image-slot-desktop', 'banner-tpl-desktop', window.__bannerRandomIndex.desktop);
				bindFallbackInNode(container.querySelector('.banner-image-slot-mobile'));
				bindFallbackInNode(container.querySelector('.banner-image-slot-desktop'));

				// 收集所有帧 HTML 字符串（仅首次）
				if (!window.__bannerCarouselFrames) window.__bannerCarouselFrames = {};

				function collectFrames(slotClass, tplClass) {
					if (window.__bannerCarouselFrames[slotClass]) return;
					var frames = [];
					var initialFrame = window.__bannerInitialFrameHtml && window.__bannerInitialFrameHtml[slotClass];
					var slot = container.querySelector('.' + slotClass);
					if (initialFrame) {
						frames.push(initialFrame);
					} else if (slot) {
						frames.push(slot.innerHTML);
					}
					var tpls = container.querySelectorAll('.' + tplClass);
					for (var i = 0; i < tpls.length; i++) {
						frames.push(tpls[i].innerHTML);
					}
					window.__bannerCarouselFrames[slotClass] = frames;
				}

				function prewarmNextFrame(slotClass, type) {
					var frames = window.__bannerCarouselFrames[slotClass];
					if (!frames || frames.length <= 1) return;

					var currentIndex = window.__bannerCarouselIndex[type] || 0;
					var nextIndex = (currentIndex + 1) % frames.length;

					var holder = document.createElement('div');
					holder.innerHTML = frames[nextIndex];
					var nextImage = holder.querySelector('img');
					if (!nextImage) return;

					var src = nextImage.getAttribute('src');
					if (src && !preloadedSources.has(src)) {
						var preloadImage = new Image();
						preloadImage.decoding = 'async';
						preloadImage.src = src;
						preloadedSources.add(src);
					}
				}

				collectFrames('banner-image-slot-mobile', 'banner-tpl-mobile');
				collectFrames('banner-image-slot-desktop', 'banner-tpl-desktop');

				if (typeof window.__bannerCarouselIndex === 'undefined') {
					window.__bannerCarouselIndex = {
						mobile: window.__bannerRandomIndex ? window.__bannerRandomIndex.mobile : 0,
						desktop: window.__bannerRandomIndex ? window.__bannerRandomIndex.desktop : 0
					};
				}

				// 断点检测（md = 768px）
				function isSlotHiddenByBreakpoint(slot) {
					var cl = slot.classList;
					var isMd = window.matchMedia('(min-width: 768px)').matches;
					if (cl.contains('md:hidden') && isMd) return true;
					if (cl.contains('hidden') && !cl.contains('md:hidden') && !isMd) return true;
					return false;
				}

				// 给首张图启动 Ken Burns
				function applyInitialKB(slotClass) {
					var slot = container.querySelector('.' + slotClass);
					if (!slot || isSlotHiddenByBreakpoint(slot)) return;
					bindFallbackInNode(slot);
					slot.classList.remove('banner-kb');
					void slot.offsetWidth;
					slot.classList.add('banner-kb');
				}

				// 暂停 Ken Burns 动画（保持当前进度）
				function pauseKenBurns() {
					var slots = container.querySelectorAll('.banner-kb');
					for (var i = 0; i < slots.length; i++) {
						slots[i].style.animationPlayState = 'paused';
					}
				}

				// 恢复 Ken Burns 动画（从暂停位置继续）
				function resumeKenBurns() {
					var slots = container.querySelectorAll('.banner-kb');
					for (var i = 0; i < slots.length; i++) {
						slots[i].style.animationPlayState = 'running';
					}
				}

				// Crossfade 防重入锁（每种 slot 类型独立）
				var isCrossfading = { mobile: false, desktop: false };

				// 清理 orphaned 中间层（快速滑动时可能残留）
				function cleanupOrphanedLayers(slotClass, currentSlot) {
					var allSlots = container.querySelectorAll('.' + slotClass);
					for (var i = 0; i < allSlots.length; i++) {
						if (allSlots[i] !== currentSlot && allSlots[i].parentNode) {
							allSlots[i].parentNode.removeChild(allSlots[i]);
						}
					}
				}

				// Crossfade：创建新层叠在旧层上方，淡入后移除旧层
				function crossfadeToIndex(slotClass, totalCount, type, targetIndex) {
					if (totalCount <= 1) return;
					if (isCrossfading[type]) return;

					var frames = window.__bannerCarouselFrames[slotClass];
					if (!frames || frames.length === 0) return;

					var oldSlot = container.querySelector('.' + slotClass);
					if (!oldSlot) return;
					if (isSlotHiddenByBreakpoint(oldSlot)) return;

					isCrossfading[type] = true;
					window.__bannerCarouselIndex[type] = targetIndex;

					// 清理快速交互可能残留的中间层
					cleanupOrphanedLayers(slotClass, oldSlot);

					var newSlot = document.createElement('div');
					var baseClass = oldSlot.className.replace(/\bbanner-kb\b/g, '').trim();
					newSlot.className = baseClass;
					newSlot.style.opacity = '0';
					newSlot.style.transition = 'opacity ' + FADE_MS + 'ms ease-in-out';
					newSlot.innerHTML = frames[targetIndex];
					bindFallbackInNode(newSlot);
					oldSlot.parentNode.insertBefore(newSlot, oldSlot.nextSibling);

					// 双 rAF：确保 opacity:0 已绘制，然后同时触发淡入 + Ken Burns
					requestAnimationFrame(function() {
						requestAnimationFrame(function() {
							newSlot.style.opacity = '1';
							newSlot.classList.add('banner-kb');
						});
					});

					// 淡入完成后：移除旧层，清理 transition，释放锁
					setTimeout(function() {
						if (oldSlot.parentNode) oldSlot.parentNode.removeChild(oldSlot);
						newSlot.style.transition = '';
						isCrossfading[type] = false;
					}, FADE_MS + 50);

					prewarmNextFrame(slotClass, type);
				}

				// 自动轮播用的 crossfade（前进到下一张）
				function crossfade(slotClass, totalCount, type) {
					var frames = window.__bannerCarouselFrames[slotClass];
					if (!frames || frames.length === 0) return;
					var currentIndex = window.__bannerCarouselIndex[type];
					var nextIndex = (currentIndex + 1) % frames.length;
					crossfadeToIndex(slotClass, totalCount, type, nextIndex);
				}

				var timerId = null;
				var isPaused = false;
				var intervalStartTime = 0;
				var remainingTime = 0;
				var resumeTimerId = null;

				// 触摸手势状态
				var touchStartX = 0;
				var touchStartY = 0;
				var isSwiping = false;

				function startCarousel(isFromResume) {
					stopCarousel();
					if (isPaused) return;

					if (!isFromResume) {
						applyInitialKB('banner-image-slot-mobile');
						applyInitialKB('banner-image-slot-desktop');
					}

					prewarmNextFrame('banner-image-slot-mobile', 'mobile');
					prewarmNextFrame('banner-image-slot-desktop', 'desktop');

					intervalStartTime = Date.now();
					timerId = setInterval(function() {
						if (!isPaused) {
							intervalStartTime = Date.now();
							crossfade('banner-image-slot-mobile', mobileCount, 'mobile');
							crossfade('banner-image-slot-desktop', desktopCount, 'desktop');
						}
					}, interval);
				}

				function stopCarousel() {
					if (resumeTimerId !== null) {
						clearTimeout(resumeTimerId);
						resumeTimerId = null;
					}
					if (timerId !== null) {
						var elapsed = Date.now() - intervalStartTime;
						remainingTime = Math.max(0, interval - elapsed);
						clearInterval(timerId);
						timerId = null;
					}
				}

				// 页面可见性：后台标签页暂停轮播
				var visibilityHandler = function() {
					if (document.hidden) {
						stopCarousel();
						pauseKenBurns();
					} else if (!isPaused) {
						resumeKenBurns();
						if (remainingTime > 0) {
							resumeTimerId = setTimeout(function() {
								resumeTimerId = null;
								crossfade('banner-image-slot-mobile', mobileCount, 'mobile');
								crossfade('banner-image-slot-desktop', desktopCount, 'desktop');
								startCarousel(true);
							}, remainingTime);
						} else {
							startCarousel(true);
						}
					}
				};
				document.addEventListener('visibilitychange', visibilityHandler);

				// 事件处理函数引用（用于清理）
				var onTouchStart = function(e) {
					touchStartX = e.touches[0].clientX;
					touchStartY = e.touches[0].clientY;
					isSwiping = false;
					isPaused = true;
					stopCarousel();
				};

				var onTouchMove = function(e) {
					if (!touchStartX || !touchStartY) return;
					var diffX = Math.abs(e.touches[0].clientX - touchStartX);
					var diffY = Math.abs(e.touches[0].clientY - touchStartY);
					if (diffX > diffY && diffX > 30) {
						isSwiping = true;
						e.preventDefault();
					}
				};

				var onTouchEnd = function(e) {
					if (!touchStartX || !touchStartY || !isSwiping) {
						isPaused = false;
						resumeKenBurns();
						if (remainingTime > 0) {
							resumeTimerId = setTimeout(function() {
								resumeTimerId = null;
								crossfade('banner-image-slot-mobile', mobileCount, 'mobile');
								crossfade('banner-image-slot-desktop', desktopCount, 'desktop');
								startCarousel(true);
							}, remainingTime);
						} else {
							startCarousel(true);
						}
						return;
					}

					var endX = e.changedTouches[0].clientX;
					var diffX = touchStartX - endX;
					var isMobile = window.innerWidth < 768;
					var slotClass = isMobile
						? 'banner-image-slot-mobile'
						: 'banner-image-slot-desktop';
					var type = isMobile ? 'mobile' : 'desktop';
					var count = isMobile ? mobileCount : desktopCount;
					var current = window.__bannerCarouselIndex[type];

					if (Math.abs(diffX) > 50) {
						if (diffX > 0) {
							var next = (current + 1) % count;
							crossfadeToIndex(slotClass, count, type, next);
						} else {
							var prev = (current - 1 + count) % count;
							crossfadeToIndex(slotClass, count, type, prev);
						}
					}

					touchStartX = 0;
					touchStartY = 0;
					isSwiping = false;
					isPaused = false;
					startCarousel();
				};

				var onMouseEnter = function() {
					isPaused = true;
					stopCarousel();
					pauseKenBurns();
				};

				var onMouseLeave = function() {
					isPaused = false;
					resumeKenBurns();
					if (remainingTime > 0) {
						resumeTimerId = setTimeout(function() {
							resumeTimerId = null;
							crossfade('banner-image-slot-mobile', mobileCount, 'mobile');
							crossfade('banner-image-slot-desktop', desktopCount, 'desktop');
							startCarousel(true);
						}, remainingTime);
					} else {
						startCarousel(true);
					}
				};

				// 移动端触摸事件
				if ('ontouchstart' in window) {
					container.addEventListener('touchstart', onTouchStart, { passive: true });
					container.addEventListener('touchmove', onTouchMove, { passive: false });
					container.addEventListener('touchend', onTouchEnd, { passive: true });
				}

				// 鼠标悬停暂停（桌面端）
				container.addEventListener('mouseenter', onMouseEnter);
				container.addEventListener('mouseleave', onMouseLeave);

				startCarousel();

				// 注册清理函数，供下次 Swup 导航或销毁时调用
				window.__bannerCarouselCleanup = function() {
					stopCarousel();
					remainingTime = 0;
					intervalStartTime = 0;
					document.removeEventListener('visibilitychange', visibilityHandler);
					if ('ontouchstart' in window) {
						container.removeEventListener('touchstart', onTouchStart);
						container.removeEventListener('touchmove', onTouchMove);
						container.removeEventListener('touchend', onTouchEnd);
					}
					container.removeEventListener('mouseenter', onMouseEnter);
					container.removeEventListener('mouseleave', onMouseLeave);
					isCrossfading = { mobile: false, desktop: false };
				};
			})();
		</script>
	)}

	<!-- Banner 5x5 网格平滑倾斜：保留 tracker/canvas 结构，使用 RAF 插值提高流畅度 -->
	<script is:inline data-swup-ignore-script>
		(function initBannerTilt() {
			var root = document.getElementById("banner-wrapper");
			if (!root) {return;}

			if (window.__bannerTiltCleanup) {
				window.__bannerTiltCleanup();
				window.__bannerTiltCleanup = null;
			}

			var canvas = root.querySelector(".banner-tilt-canvas");
			var panel = root.querySelector(".banner-tilt-panel");
			if (!canvas || !panel) {return;}

			var canHover = window.matchMedia("(hover: hover)").matches;
			var reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

			if (!canHover || reduceMotion) {
				panel.style.setProperty("--tilt-x", "0deg");
				panel.style.setProperty("--tilt-y", "0deg");
				panel.classList.remove("is-tilting");
				return;
			}

			var MAX_ROTATE_X = 11;
			var MAX_ROTATE_Y = 7;
			var FOLLOW_FACTOR = 0.14;

			var targetX = 0;
			var targetY = 0;
			var currentX = 0;
			var currentY = 0;
			var rafId = null;
			var rect = null;
			var needRectUpdate = true;
			var isInside = false;

			function softCurve(value) {
				var clamped = Math.max(-1, Math.min(1, value));
				return Math.sin(clamped * Math.PI * 0.5);
			}

			function updateRect() {
				rect = canvas.getBoundingClientRect();
				needRectUpdate = false;
			}

			function queueTick() {
				if (rafId !== null) {return;}
				rafId = requestAnimationFrame(tick);
			}

			function tick() {
				rafId = null;

				currentX += (targetX - currentX) * FOLLOW_FACTOR;
				currentY += (targetY - currentY) * FOLLOW_FACTOR;

				if (Math.abs(targetX - currentX) < 0.01) {currentX = targetX;}
				if (Math.abs(targetY - currentY) < 0.01) {currentY = targetY;}

				panel.style.setProperty("--tilt-x", currentX.toFixed(3) + "deg");
				panel.style.setProperty("--tilt-y", currentY.toFixed(3) + "deg");

				if (
					isInside ||
					Math.abs(targetX - currentX) > 0.01 ||
					Math.abs(targetY - currentY) > 0.01
				) {
					queueTick();
				}
			}

			function setTargetFromPointer(event) {
				if (needRectUpdate || !rect) {
					updateRect();
				}

				var relativeX = (event.clientX - rect.left) / rect.width;
				var relativeY = (event.clientY - rect.top) / rect.height;

				var normalizedX = softCurve(relativeX * 2 - 1);
				var normalizedY = softCurve(1 - relativeY * 2);

				targetX = normalizedY * MAX_ROTATE_X;
				targetY = normalizedX * MAX_ROTATE_Y;
				panel.classList.add("is-tilting");
				queueTick();
			}

			function onPointerEnter(event) {
				isInside = true;
				needRectUpdate = true;
				setTargetFromPointer(event);
			}

			function onPointerMove(event) {
				if (!isInside) {return;}
				setTargetFromPointer(event);
			}

			function onPointerLeave() {
				isInside = false;
				targetX = 0;
				targetY = 0;
				panel.classList.remove("is-tilting");
				queueTick();
			}

			function onViewportChange() {
				needRectUpdate = true;
			}

			canvas.addEventListener("pointerenter", onPointerEnter);
			canvas.addEventListener("pointermove", onPointerMove);
			canvas.addEventListener("pointerleave", onPointerLeave);
			window.addEventListener("resize", onViewportChange, { passive: true });
			window.addEventListener("scroll", onViewportChange, { passive: true });

			window.__bannerTiltCleanup = function() {
				canvas.removeEventListener("pointerenter", onPointerEnter);
				canvas.removeEventListener("pointermove", onPointerMove);
				canvas.removeEventListener("pointerleave", onPointerLeave);
				window.removeEventListener("resize", onViewportChange);
				window.removeEventListener("scroll", onViewportChange);

				if (rafId !== null) {
					cancelAnimationFrame(rafId);
					rafId = null;
				}

				panel.style.setProperty("--tilt-x", "0deg");
				panel.style.setProperty("--tilt-y", "0deg");
				panel.classList.remove("is-tilting");
			};
		})();
	</script>

	<!-- 首页文字覆盖层 -->
	{siteConfig.banner.homeText?.enable && (
