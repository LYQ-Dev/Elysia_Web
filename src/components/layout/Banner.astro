<style>
	/* Banner 图片层 5x5 追踪网格视差 */
	.banner-tilt-container {
		position: relative;
		width: 100%;
		height: 100%;
		perspective: 1200px;
		isolation: isolate;
		--banner-edge-radius: clamp(0.7rem, 1.6vw, 1.2rem);
		--edge-fade-size: clamp(2.4rem, 7vh, 4.4rem);
		--edge-fade-bottom-size: clamp(3.4rem, 10vh, 6rem);
		border-radius: var(--banner-edge-radius);
		overflow: hidden;
		background: var(--page-bg);
	}

	.banner-tilt-canvas {
		position: absolute;
		inset: 0;
		z-index: 3;
		border-radius: inherit;
		overflow: hidden;
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		grid-template-rows: repeat(5, minmax(0, 1fr));
	}

	.banner-tracker {
		width: 100%;
		height: 100%;
		cursor: pointer;
	}

	.banner-tilt-panel {
		position: relative;
		z-index: 1;
		width: 100%;
		height: 100%;
		border-radius: inherit;
		overflow: hidden;
		background: var(--page-bg);
		/* Use panel-attached page-bg shadow to hide sub-pixel seam under tilt */
		box-shadow: 0 1px 0 var(--page-bg), 0 2px 0 var(--page-bg);
		transform: scale(1.022) rotateX(var(--tilt-x, 0deg)) rotateY(var(--tilt-y, 0deg)) translateZ(0);
		transform-origin: center center;
		transform-style: preserve-3d;
		backface-visibility: hidden;
		contain: layout style paint;
		will-change: transform, filter;
		transition: filter 240ms ease;
	}

	.banner-tilt-panel::before {
		content: "";
		position: absolute;
		inset: -1.25rem;
		border-radius: inherit;
		background: var(--page-bg);
		filter: none;
		opacity: 1;
		pointer-events: none;
		transition: none;
		z-index: -1;
	}

	.banner-tilt-panel.with-attached-fade::after {
		content: "";
		position: absolute;
		inset: 0;
		border-radius: inherit;
		pointer-events: none;
		z-index: 2;
		background: linear-gradient(
			to bottom,
			color-mix(in oklab, var(--page-bg) 56%, transparent) 0%,
			color-mix(in oklab, var(--page-bg) 22%, transparent) 58%,
			transparent 100%
		),
		linear-gradient(
			to top,
			var(--page-bg) 0%,
			color-mix(in oklab, var(--page-bg) 88%, transparent) 36%,
			color-mix(in oklab, var(--page-bg) 52%, transparent) 68%,
			transparent 100%
		),
		linear-gradient(
			to right,
			color-mix(in oklab, var(--page-bg) 62%, transparent) 0%,
			color-mix(in oklab, var(--page-bg) 22%, transparent) 60%,
			transparent 100%
		),
		linear-gradient(
			to left,
			color-mix(in oklab, var(--page-bg) 62%, transparent) 0%,
			color-mix(in oklab, var(--page-bg) 22%, transparent) 60%,
			transparent 100%
		);
		background-size:
			100% var(--edge-fade-size),
			100% var(--edge-fade-bottom-size),
			var(--edge-fade-size) 100%,
			var(--edge-fade-size) 100%;
		background-position: top center, bottom center, left center, right center;
		background-repeat: no-repeat;
		-webkit-backdrop-filter: none;
		backdrop-filter: none;
		transform: translateZ(0);
	}

	.banner-tilt-panel #banner-carousel,
	.banner-tilt-panel #banner-single-container {
		position: relative;
		z-index: 1;
	}

	.banner-tilt-panel.is-tilting {
		filter: brightness(1.01) saturate(1.005);
	}

	.banner-tilt-panel.is-tilting::before {
		opacity: 1;
	}

	.banner-bottom-solid-strip-attached {
		position: absolute;
		left: -0.3rem;
		right: -0.3rem;
		bottom: -1px;
		height: clamp(7px, 0.75vw, 12px);
		border-radius: 0 0 var(--banner-edge-radius) var(--banner-edge-radius);
		background: var(--page-bg);
		pointer-events: none;
		z-index: 4;
		transform: translateZ(0);
		box-shadow: 0 2px 0 var(--page-bg);
	}

	#banner-wrapper {
		background: var(--page-bg);
	}

	#banner-wrapper::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		bottom: -1px;
		height: 4px;
		background: var(--page-bg);
		pointer-events: none;
		z-index: 24;
	}

	@media (hover: none), (pointer: coarse) {
		.banner-tilt-canvas {
			display: none;
		}

		.banner-tilt-panel {
			transform: none !important;
			filter: none;
			transition: filter 180ms ease;
		}

		.banner-tilt-panel::before {
			opacity: 1;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.banner-tilt-panel {
			transform: none !important;
			transition: filter 200ms ease-in-out;
		}
	}

	.banner-image-unavailable {
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0.06));
	}

	/* Banner 文本样式 */
	.banner-title {
		text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.7);
		animation: fadeInUp 1s ease-out;
		font-weight: bold;
	}

	.banner-subtitle {
		text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.6);
		animation: fadeInUp 1s ease-out 0.3s both;
		min-height: 1.5em;
		line-height: 1.2;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(30px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>
