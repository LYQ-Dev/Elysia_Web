---
import { siteConfig } from "../../../config";
import { widgetManager } from "../../../utils/widget-manager";
import PostCard from "./PostCard.astro";
import type { PostPageProps } from "./types";

const { page }: PostPageProps = Astro.props as PostPageProps;

const hasRightSidebars =
	widgetManager.getComponentsByPosition("top", "right", "desktop").length >
		0 ||
	widgetManager.getComponentsByPosition("sticky", "right", "desktop").length >
		0;

const defaultLayout = siteConfig.postListLayout.defaultMode || "list";
const initialLayoutClass = defaultLayout === "grid" ? "grid-mode" : "list-mode";
---

<div
	id="post-list-container"
	class={`transition-all duration-500 ease-in-out rounded-[var(--radius-large)] bg-[var(--card-bg)] md:bg-transparent mb-4 ${initialLayoutClass}`}
	data-default-layout={defaultLayout}
	data-both-sidebars={hasRightSidebars}
>
	{
		page.data.map((entry, index) => (
			<PostCard
				entry={entry}
				class:list="onload-animation"
				style={`--i: ${index}; --interval: 50ms;`}
			/>
		))
	}
</div>

<script>
	const postTiltCleanupMap = new Map<HTMLElement, () => void>();

	function initLayout() {
		requestAnimationFrame(() => {
			const postListContainer = document.getElementById(
				"post-list-container",
			);
			if (!postListContainer) {
				return;
			}

			const savedLayout = localStorage.getItem("postListLayout");
			const defaultLayout =
				postListContainer.getAttribute("data-default-layout") || "list";
			const currentLayout = savedLayout || defaultLayout;

			const hasGridClass =
				postListContainer.classList.contains("grid-mode");
			const isClassCorrect =
				(currentLayout === "grid" && hasGridClass) ||
				(currentLayout === "list" && !hasGridClass);

			if (isClassCorrect) {
				postListContainer.classList.add("js-initialized");
				initPostCardTilt();
				publishLayoutInit();
				return;
			}

			if (window.innerWidth >= 769) {
				updatePostListLayout(currentLayout);
			} else {
				postListContainer.classList.add("js-initialized");
			}

			initPostCardTilt();
			publishLayoutInit();
		});
	}

	function cleanupAllPostCardTilt() {
		postTiltCleanupMap.forEach((cleanup, card) => {
			cleanup();
			card.removeAttribute("data-post-tilt-bound");
		});
		postTiltCleanupMap.clear();

		document
			.querySelectorAll<HTMLElement>('[data-post-tilt-card="true"]')
			.forEach((card) => {
				card.style.removeProperty("transform");
				card.classList.remove("is-tilting");
				card.removeAttribute("data-post-tilt-bound");
			});
	}

	function pruneDetachedPostCardTilt() {
		postTiltCleanupMap.forEach((cleanup, card) => {
			if (!document.body.contains(card)) {
				cleanup();
				postTiltCleanupMap.delete(card);
			}
		});
	}

	function initPostCardTilt() {
		pruneDetachedPostCardTilt();

		const isHomePage = document.body.classList.contains("lg:is-home");
		const canHover = window.matchMedia(
			"(hover: hover) and (pointer: fine)",
		).matches;
		const reduceMotion = window.matchMedia(
			"(prefers-reduced-motion: reduce)",
		).matches;

		if (!isHomePage || !canHover || reduceMotion) {
			cleanupAllPostCardTilt();
			return;
		}

		const cards = document.querySelectorAll<HTMLElement>(
			'[data-post-tilt-card="true"]',
		);
		cards.forEach((card) => {
			if (card.dataset.postTiltBound === "true") {
				return;
			}

			card.dataset.postTiltBound = "true";

			const MAX_ROTATE_X = 12;
			const MAX_ROTATE_Y = 8;
			const FOLLOW_FACTOR = 0.16;

			let targetX = 0;
			let targetY = 0;
			let currentX = 0;
			let currentY = 0;
			let rafId: number | null = null;
			let isInside = false;

			function softCurve(value: number): number {
				const clamped = Math.max(-1, Math.min(1, value));
				return Math.sin(clamped * Math.PI * 0.5);
			}

			function queueTick() {
				if (rafId !== null) {
					return;
				}
				rafId = requestAnimationFrame(tick);
			}

			function resetTransform() {
				card.style.removeProperty("transform");
				card.classList.remove("is-tilting");
			}

			function tick() {
				rafId = null;

				currentX += (targetX - currentX) * FOLLOW_FACTOR;
				currentY += (targetY - currentY) * FOLLOW_FACTOR;

				if (Math.abs(targetX - currentX) < 0.01) {
					currentX = targetX;
				}
				if (Math.abs(targetY - currentY) < 0.01) {
					currentY = targetY;
				}

				if (
					!isInside &&
					Math.abs(currentX) < 0.01 &&
					Math.abs(currentY) < 0.01 &&
					Math.abs(targetX) < 0.01 &&
					Math.abs(targetY) < 0.01
				) {
					resetTransform();
					return;
				}

				card.style.setProperty(
					"transform",
					`perspective(1200px) rotateX(${currentX.toFixed(3)}deg) rotateY(${currentY.toFixed(3)}deg) translateZ(0)`,
					"important",
				);
				card.classList.add("is-tilting");

				if (
					isInside ||
					Math.abs(targetX - currentX) > 0.01 ||
					Math.abs(targetY - currentY) > 0.01
				) {
					queueTick();
				}
			}

			function setTargetFromPointer(event: PointerEvent) {
				const rect = card.getBoundingClientRect();
				if (rect.width === 0 || rect.height === 0) {
					return;
				}

				const relativeX = (event.clientX - rect.left) / rect.width;
				const relativeY = (event.clientY - rect.top) / rect.height;

				const normalizedX = softCurve(relativeX * 2 - 1);
				const normalizedY = softCurve(1 - relativeY * 2);

				targetX = normalizedY * MAX_ROTATE_X;
				targetY = normalizedX * MAX_ROTATE_Y;
				queueTick();
			}

			function onPointerEnter(event: PointerEvent) {
				isInside = true;
				setTargetFromPointer(event);
			}

			function onPointerMove(event: PointerEvent) {
				if (!isInside) {
					return;
				}
				setTargetFromPointer(event);
			}

			function onPointerLeave() {
				isInside = false;
				targetX = 0;
				targetY = 0;
				queueTick();
			}

			card.addEventListener("pointerenter", onPointerEnter);
			card.addEventListener("pointermove", onPointerMove);
			card.addEventListener("pointerleave", onPointerLeave);

			postTiltCleanupMap.set(card, () => {
				card.removeEventListener("pointerenter", onPointerEnter);
				card.removeEventListener("pointermove", onPointerMove);
				card.removeEventListener("pointerleave", onPointerLeave);

				if (rafId !== null) {
					cancelAnimationFrame(rafId);
					rafId = null;
				}

				resetTransform();
			});
		});
	}

	function updatePostListLayout(layout: string) {
		const container = document.getElementById("post-list-container");
		if (!container) {
			return;
		}

		container.classList.add("layout-switching");

		if (layout === "grid") {
			container.classList.remove("list-mode");
			container.classList.add("grid-mode");

			const rightSidebar = document.querySelector(
				".right-sidebar-container",
			);
			if (rightSidebar) {
				rightSidebar.classList.add("hidden-in-grid-mode");
			}

			const mainGrid = document.getElementById("main-grid");
			if (mainGrid) {
				mainGrid.setAttribute("data-layout-mode", "grid");
			}
		} else {
			container.classList.remove("grid-mode");
			container.classList.add("list-mode");

			const rightSidebar = document.querySelector(
				".right-sidebar-container",
			);
			if (rightSidebar) {
				rightSidebar.classList.remove("hidden-in-grid-mode");
			}

			const mainGrid = document.getElementById("main-grid");
			if (mainGrid) {
				mainGrid.setAttribute("data-layout-mode", "list");
			}
		}

		container.classList.add("js-initialized");

		setTimeout(() => {
			container.classList.remove("layout-switching");
		}, 500);
	}

	window.addEventListener("layoutChange", (event: any) => {
		if (event.detail?.layout) {
			updatePostListLayout(event.detail.layout);
		}
	});

	let resizeTimeout: number | undefined;
	window.addEventListener("resize", () => {
		clearTimeout(resizeTimeout);
		resizeTimeout = window.setTimeout(() => {
			if (window.innerWidth >= 769) {
				const savedLayout = localStorage.getItem("postListLayout");
				const defaultLayout =
					document
						.getElementById("post-list-container")
						?.getAttribute("data-default-layout") || "list";
				updatePostListLayout(savedLayout || defaultLayout);
			}
		}, 100);
	});

	document.addEventListener("DOMContentLoaded", initLayout);
	if (document.readyState !== "loading") {
		initLayout();
	}

	function setupSwupListeners() {
		if ((window as any)._postListSwupListenerAttached) {
			return;
		}

		function trySetupSwup() {
			if (typeof window !== "undefined" && (window as any).swup) {
				(window as any).swup.hooks.on("content:replace", initLayout);
				(window as any)._postListSwupListenerAttached = true;
				return true;
			}
			return false;
		}

		if (!trySetupSwup()) {
			let retryCount = 0;
			const retryInterval = setInterval(() => {
				if (trySetupSwup() || ++retryCount >= 10) {
					clearInterval(retryInterval);
					if (retryCount >= 10) {
						window.addEventListener("popstate", () =>
							requestAnimationFrame(initLayout),
						);
					}
				}
			}, 100);
		}
	}
	setTimeout(setupSwupListeners, 200);

	function publishLayoutInit() {
		const container = document.getElementById("post-list-container");
		if (container) {
			const layout = container.classList.contains("grid-mode")
				? "grid"
				: "list";
			window.dispatchEvent(
				new CustomEvent("layoutInit", { detail: { layout } }),
			);
		}
	}
	setTimeout(publishLayoutInit, 150);
</script>

<style>
	@reference "tailwindcss";

	#post-list-container {
		min-height: 200px;
		transition: opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1);
	}

	#post-list-container.list-mode {
		@apply flex flex-col gap-4;
	}

	#post-list-container.grid-mode {
		@apply grid grid-cols-1 md:grid-cols-2 gap-6;
	}

	#post-list-container > :global(*) {
		content-visibility: auto;
		contain-intrinsic-size: 200px;
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		opacity: 0;
		animation: fadeInSlide 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
		animation-delay: calc(
			var(--content-delay) + var(--i) * var(--interval)
		);
	}

	#post-list-container.grid-mode > :global(*) {
		animation-name: fadeInScale;
	}

	#post-list-container.layout-switching {
		opacity: 0.95;
	}

	#post-list-container.layout-switching > :global(*) {
		animation-delay: calc(var(--i) * 50ms);
	}

	#post-list-container.layout-switching > :global(*) {
		transform: scale(0.98);
	}

	@keyframes fadeInScale {
		from {
			opacity: 0;
			transform: scale(0.95);
		}
		to {
			opacity: 1;
			transform: scale(1);
		}
	}

	@keyframes fadeInSlide {
		from {
			opacity: 0;
			transform: translateX(-10px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}
</style>
