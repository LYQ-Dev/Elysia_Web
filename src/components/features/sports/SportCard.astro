---
import { Icon } from "astro-icon/components";

export interface Props {
	id: string;
	title: string;
	category: "cardio" | "strength" | "flexibility" | "ball" | "outdoor" | "other";
	duration: number;
	distance?: number;
	calories?: number;
	difficulty: "easy" | "medium" | "hard";
	location?: string;
	date: string;
	image?: string;
	tags?: string[];
}

const { id, title, category, duration, distance, calories, difficulty, location, date, image, tags = [] } = Astro.props as Props;
const detailLink = `/sports/${id}/`;

const getCategoryIcon = (cat: string) => {
	const iconMap: Record<string, string> = {
		cardio: "material-symbols:directions-run",
		strength: "material-symbols:fitness-center",
		flexibility: "material-symbols:self-improvement",
		ball: "material-symbols:sports-basketball",
		outdoor: "material-symbols:forest",
		other: "material-symbols:sports-score",
	};
	return iconMap[cat] || "material-symbols:sports-score";
};

const getDifficultyColor = (diff: string) => {
	const colors: Record<string, string> = {
		easy: "bg-green-500/10 text-green-600 dark:text-green-400",
		medium: "bg-amber-500/10 text-amber-600 dark:text-amber-400",
		hard: "bg-red-500/10 text-red-600 dark:text-red-400",
	};
	return colors[diff] || "bg-gray-500/10 text-gray-600 dark:text-gray-400";
};

const getCategoryText = (cat: string) => {
	const texts: Record<string, string> = {
		cardio: "有氧运动",
		strength: "力量训练",
		flexibility: "柔韧性",
		ball: "球类运动",
		outdoor: "户外运动",
		other: "其他",
	};
	return texts[cat] || cat;
};
---

<a href={detailLink} class="sport-card group relative rounded-xl border border-black/10 dark:border-white/10 overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-1 block h-full">
	<!-- 图片或色彩背景 -->
	<div class="aspect-video overflow-hidden relative bg-gradient-to-br from-orange-500/5 to-red-500/10">
		{image ? (
			<img
				src={image}
				alt={title}
				class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
				loading="lazy"
			/>
		) : (
			<div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-orange-500/10 to-red-500/10">
				<Icon name={getCategoryIcon(category)} class="w-16 h-16 text-orange-500/30" />
			</div>
		)}
		<!-- 难度标记 -->
		<div class={`absolute top-3 right-3 px-2.5 py-1.5 rounded-lg text-xs font-medium backdrop-blur ${getDifficultyColor(difficulty)}`}>
			{difficulty === "easy" ? "简单" : difficulty === "medium" ? "中等" : "困难"}
		</div>
		<div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
	</div>

	<!-- 内容区域 -->
	<div class="p-3">
		<!-- 标题和日期 -->
		<h3 class="text-sm font-bold text-black/90 dark:text-white/90 truncate group-hover:text-orange-600 dark:group-hover:text-orange-400 transition-colors duration-200 mb-2">
			{title}
		</h3>
		<p class="text-xs text-black/50 dark:text-white/50 mb-3">
			{new Date(date).toLocaleDateString("zh-CN", { month: "short", day: "numeric" })}
		</p>

		<!-- 运动统计 -->
		<div class="grid grid-cols-2 gap-2 mb-3">
			<div class="flex items-center gap-1.5 text-xs">
				<Icon name="material-symbols:schedule" class="w-3.5 h-3.5 text-black/40 dark:text-white/40" />
				<span class="text-black/60 dark:text-white/60">{duration} 分钟</span>
			</div>
			{distance && (
				<div class="flex items-center gap-1.5 text-xs">
					<Icon name="material-symbols:distance" class="w-3.5 h-3.5 text-black/40 dark:text-white/40" />
					<span class="text-black/60 dark:text-white/60">{distance} km</span>
				</div>
			)}
			{calories && (
				<div class="flex items-center gap-1.5 text-xs col-span-2">
					<Icon name="material-symbols:local-fire-department" class="w-3.5 h-3.5 text-black/40 dark:text-white/40" />
					<span class="text-black/60 dark:text-white/60">{calories} kcal</span>
				</div>
			)}
		</div>

		<!-- 类别和位置 -->
		<div class="flex items-center gap-2 mb-3">
			<span class="px-2 py-0.5 text-xs rounded-full bg-orange-500/10 text-orange-600 dark:text-orange-400 font-medium">
				{getCategoryText(category)}
			</span>
			{location && (
				<span class="px-2 py-0.5 text-xs rounded-full bg-black/5 dark:bg-white/5 text-black/50 dark:text-white/50 font-medium truncate">
					{location}
				</span>
			)}
		</div>

		<!-- 标签 -->
		{tags && tags.length > 0 && (
			<div class="flex flex-wrap gap-1.5">
				{tags.slice(0, 2).map((tag) => (
					<span class="px-2 py-0.5 text-xs rounded-full bg-orange-500/10 text-orange-600 dark:text-orange-400 font-medium">
						{tag}
					</span>
				))}
				{tags.length > 2 && (
					<span class="px-2 py-0.5 text-xs rounded-full bg-black/5 dark:bg-white/5 text-black/50 dark:text-white/50 font-medium">
						+{tags.length - 2}
					</span>
				)}
			</div>
		)}
	</div>

	<!-- 悬停渐变背景 -->
	<div class="absolute inset-0 bg-gradient-to-br from-orange-500/5 to-red-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" />
</a>

<style>
	.sport-card {
		animation: fadeInUp 0.5s ease-out forwards;
		opacity: 0;
	}

	.sport-card.filtered-out {
		display: none;
	}
</style>
