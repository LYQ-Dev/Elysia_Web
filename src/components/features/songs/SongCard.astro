---
import { Icon } from "astro-icon/components";

export interface Props {
	id: string;
	title: string;
	artist: string;
	album: string;
	cover?: string;
	link?: string;
	tags?: string[];
	rating?: number;
	description?: string;
}

const { id, title, artist, album, cover, link, tags = [], rating = 5, description } = Astro.props as Props;
const detailLink = `/music/${id}/`;
---

<a href={detailLink} class="song-card group relative rounded-xl border border-black/10 dark:border-white/10 overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-1 block h-full">
	<!-- 封面图片 -->
	<div class="aspect-square overflow-hidden relative bg-gradient-to-br from-purple-500/5 to-pink-500/10">
		{cover ? (
			<img
				src={cover}
				alt={title}
				class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
				loading="lazy"
			/>
		) : (
			<div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-purple-500/10 to-pink-500/10">
				<Icon name="material-symbols:music-note" class="w-12 h-12 text-purple-500/30" />
			</div>
		)}
		<!-- 评分标记 -->
		{rating && (
			<div class="absolute top-3 right-3 flex items-center gap-1 bg-black/50 text-white px-2 py-1 rounded-lg text-xs font-medium backdrop-blur">
				<Icon name="material-symbols:star-rounded" class="w-3 h-3" />
				<span>{rating}</span>
			</div>
		)}
		<div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
	</div>

	<!-- 内容区域 -->
	<div class="p-3">
		<!-- 标题和艺术家 -->
		<h3 class="text-sm font-bold text-black/90 dark:text-white/90 truncate group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors duration-200 mb-1">
			{title}
		</h3>
		<p class="text-sm text-black/60 dark:text-white/60 truncate mb-2">
			{artist}
		</p>
		<p class="text-xs text-black/50 dark:text-white/50 truncate mb-3">
			{album}
		</p>

		<!-- 标签 -->
		{tags && tags.length > 0 && (
			<div class="flex flex-wrap gap-1.5 mb-3">
				{tags.slice(0, 2).map((tag) => (
					<span class="px-2 py-0.5 text-xs rounded-full bg-purple-500/10 text-purple-600 dark:text-purple-400 font-medium">
						{tag}
					</span>
				))}
				{tags.length > 2 && (
					<span class="px-2 py-0.5 text-xs rounded-full bg-black/5 dark:bg-white/5 text-black/50 dark:text-white/50 font-medium">
						+{tags.length - 2}
					</span>
				)}
			</div>
		)}

		<!-- 外部链接按钮 -->
		{link && (
			<button
				class="w-full flex items-center justify-center gap-2 px-3 py-2 rounded-lg text-sm font-medium bg-purple-500/10 text-purple-600 dark:text-purple-400 hover:bg-purple-500/20 transition-colors duration-200"
				onclick={`event.preventDefault(); window.open('${link}', '_blank');`}
			>
				<Icon name="material-symbols:open-in-new" class="w-3.5 h-3.5" />
				<span>播放</span>
			</button>
		)}
	</div>

	<!-- 悬停渐变背景 -->
	<div class="absolute inset-0 bg-gradient-to-br from-purple-500/5 to-pink-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" />
</a>

<style>
	.song-card {
		animation: fadeInUp 0.5s ease-out forwards;
		opacity: 0;
	}

	.song-card.filtered-out {
		display: none;
	}
</style>
