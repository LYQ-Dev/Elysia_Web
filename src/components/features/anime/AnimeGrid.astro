---
import AnimeCard from "./AnimeCard.astro";

interface StatusInfo {
	text: string;
	class: string;
	icon: string;
}

interface AnimeItem {
	title: string;
	cover: string;
	link: string;
	status: string;
	rating: number;
	progress: number;
	totalEpisodes: number;
	description: string;
	year: string;
	studio: string;
	genre: string[];
}

interface Props {
	visibleAnimeList: AnimeItem[];
	hiddenAnimeList: AnimeItem[];
	statusMap: Record<string, StatusInfo>;
	yearLabel: string;
	studioLabel: string;
}

const { visibleAnimeList, hiddenAnimeList, statusMap, yearLabel, studioLabel } =
	Astro.props;

const hasHiddenItems = hiddenAnimeList.length > 0;

type CardStatus = "watching" | "completed" | "planned" | "dropped";

function normalizeStatus(status: string): CardStatus {
	if (
		status === "watching" ||
		status === "completed" ||
		status === "planned" ||
		status === "dropped"
	) {
		return status;
	}

	// 将 onhold 等历史状态映射到当前卡片支持的状态
	return "planned";
}

function getFallbackId(anime: AnimeItem, index: number): string {
	const fromLink = anime.link?.match(/(?:ss|md|subject\/)(\d+)/i)?.[1];
	if (fromLink) {
		return `legacy-${fromLink}`;
	}

	const normalizedTitle = anime.title
		.toLowerCase()
		.replace(/[^a-z0-9\u4e00-\u9fa5]+/g, "-")
		.replace(/^-+|-+$/g, "");

	return normalizedTitle || `legacy-anime-${index}`;
}
---

<div
	id="anime-list-container"
	class="anime-grid-container grid gap-4 md:gap-6 opacity-0 transition-opacity duration-300"
>
	{
		visibleAnimeList.map((anime, index) => {
			const status = normalizeStatus(anime.status);
			return (
				<AnimeCard
					id={getFallbackId(anime, index)}
					title={anime.title}
					description={anime.description}
					studio={anime.studio}
					cover={anime.cover}
					status={status}
					rating={anime.rating}
					totalEpisodes={anime.totalEpisodes}
					watchedEpisodes={anime.progress}
					year={anime.year}
					genre={anime.genre}
					link={anime.link}
				/>
			);
		})
	}
</div>

<template id="anime-lazy-store">
	{
		hiddenAnimeList.map((anime, index) => {
			const status = normalizeStatus(anime.status);
			return (
				<AnimeCard
					id={getFallbackId(anime, visibleAnimeList.length + index)}
					title={anime.title}
					description={anime.description}
					studio={anime.studio}
					cover={anime.cover}
					status={status}
					rating={anime.rating}
					totalEpisodes={anime.totalEpisodes}
					watchedEpisodes={anime.progress}
					year={anime.year}
					genre={anime.genre}
					link={anime.link}
				/>
			);
		})
	}
</template>

{
	hasHiddenItems && (
		<div
			id="infinite-scroll-sentinel"
			class="w-full h-20 flex items-center justify-center mt-8"
		>
			<div class="anime-loading-spinner w-8 h-8 border-4 border-[var(--primary)] border-t-transparent rounded-full animate-spin" />
		</div>
	)
}
