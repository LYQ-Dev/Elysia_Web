---
import { Icon } from "astro-icon/components";

export interface Props {
	id: string;
	title: string;
	studio: string;
	cover?: string;
	status: "watching" | "completed" | "planned" | "dropped";
	rating?: number;
	totalEpisodes: number;
	watchedEpisodes?: number;
	year: string;
	genre?: string[];
	tags?: string[];
	link?: string;
}

const { id, title, studio, cover, status, rating = 5, totalEpisodes, watchedEpisodes = 0, year, genre = [], tags = [], link } = Astro.props as Props;
const detailLink = `/anime/${id}/`;

const getStatusInfo = (status: string) => {
	const statusMap: Record<string, { text: string; color: string; icon: string }> = {
		watching: { text: "追番中", color: "blue", icon: "material-symbols:play-circle" },
		completed: { text: "已完成", color: "green", icon: "material-symbols:check-circle" },
		planned: { text: "计划观看", color: "amber", icon: "material-symbols:schedule" },
		dropped: { text: "已弃番", color: "gray", icon: "material-symbols:cancel" },
	};
	return statusMap[status] || { text: status, color: "gray", icon: "material-symbols:play-circle" };
};

const statusInfo = getStatusInfo(status);
const colorMap: Record<string, string> = {
	blue: "bg-blue-500/10 text-blue-600 dark:text-blue-400 border-blue-600 dark:border-blue-400",
	green: "bg-green-500/10 text-green-600 dark:text-green-400 border-green-600 dark:border-green-400",
	amber: "bg-amber-500/10 text-amber-600 dark:text-amber-400 border-amber-600 dark:border-amber-400",
	gray: "bg-gray-500/10 text-gray-600 dark:text-gray-400 border-gray-600 dark:border-gray-400",
};

// 主题色映射（用于进度条）
const themeColorMap: Record<string, string> = {
	watching: "from-blue-500 to-blue-600",
	completed: "from-green-500 to-green-600",
	planned: "from-amber-500 to-amber-600",
	dropped: "from-gray-500 to-gray-600",
};

const watchProgress = totalEpisodes > 0 ? (watchedEpisodes / totalEpisodes * 100) : 0;
---

<a href={detailLink} class="anime-card group relative rounded-lg overflow-hidden flex h-[200px] transition-all will-change-transform" style="transition-property: transform, box-shadow; transition-duration: 300ms; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);">
	<!-- 左侧：封面容器 -->
	<div class="shrink-0 w-[126px] aspect-[10/16] relative bg-gradient-to-br from-black/5 to-black/10 dark:from-white/5 dark:to-white/10 overflow-hidden">
		{cover ? (
			<img
				src={cover}
				alt={title}
				class="w-full h-full object-cover transition-transform duration-300"
				style="transition-property: transform; transition-duration: 300ms; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);"
				loading="lazy"
			/>
		) : (
			<div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-red-500/10 to-pink-500/20 dark:from-red-500/5 dark:to-pink-500/10">
				<Icon name="material-symbols:movie" class="w-12 h-12 text-red-500/40 dark:text-red-400/30" />
			</div>
		)}

		<!-- 评分徽章 -->
		{rating && (
			<div class="absolute top-2 right-2 flex items-center gap-0.5 bg-black/60 text-white px-2 py-1 rounded-md text-xs font-semibold backdrop-blur-md">
				<Icon name="material-symbols:star-rounded" class="w-3 h-3" />
				<span>{rating}</span>
			</div>
		)}
	</div>

	<!-- 右侧：内容部分 -->
	<div class="flex-1 px-6 py-4 flex flex-col justify-between bg-white/50 dark:bg-white/5 backdrop-blur-sm border-l border-black/10 dark:border-white/10">
		<!-- 标题 -->
		<div class="flex flex-col gap-2">
			<h3 class="font-bold text-base leading-tight text-black/90 dark:text-white/90 line-clamp-2 group-hover:text-red-600 dark:group-hover:text-red-400" style="transition-property: color; transition-duration: 300ms; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);">
				{title}
			</h3>

			<!-- 年份 & 制作 -->
			<div class="flex items-center gap-1 text-sm text-black/50 dark:text-white/50 line-clamp-1">
				<span class="shrink-0">{year}</span>
				<span class="shrink-0">•</span>
				<span class="truncate">{studio}</span>
			</div>

			<!-- 状态 -->
			<div class="flex items-center gap-2 flex-wrap">
				<span class={`px-2 py-1 rounded text-sm font-medium flex items-center gap-1 ${colorMap[statusInfo.color]}`}>
					{statusInfo.text}
				</span>
				{genre && genre.length > 0 && (
					<span class="px-2 py-1 text-sm rounded bg-red-500/15 text-red-600 dark:text-red-400 font-medium">
						{genre[0]}
					</span>
				)}
			</div>
		</div>

		<!-- 观看进度 -->
		{totalEpisodes > 0 && (
			<div class="text-sm text-black/60 dark:text-white/60 font-medium">
				{watchedEpisodes}/{totalEpisodes}
			</div>
		)}
	</div>

	<!-- 底部进度条 -->
	<div class="anime-progress-bar absolute bottom-0 left-0 right-0 h-2 bg-black/5 dark:bg-white/5 overflow-hidden">
		<div
			class={`anime-progress-fill h-full bg-gradient-to-r ${themeColorMap[status]} transition-all will-change-transform`}
			style={`width: 0%; transition-property: width; transition-duration: 300ms; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);`}
		/>
	</div>
</a>

<style>
	.anime-card {
		animation: fadeInUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
		opacity: 0;
		border-radius: 0.5rem;
		border: 1px solid rgb(0 0 0 / 0.1);
		background: linear-gradient(135deg, rgb(255 255 255 / 0.3), rgb(255 255 255 / 0.1));
		backdrop-filter: blur(8px);
	}

	:global(.dark) .anime-card {
		border-color: rgb(255 255 255 / 0.1);
		background: linear-gradient(135deg, rgb(255 255 255 / 0.08), rgb(255 255 255 / 0.03));
	}

	.anime-card:hover {
		transform: translate3d(0, -20px, 0);
		box-shadow: 0 20px 40px rgb(0 0 0 / 0.15);
	}

	:global(.dark) .anime-card:hover {
		box-shadow: 0 20px 40px rgb(0 0 0 / 0.4);
	}

	.anime-card:hover img {
		transform: scale(1.08);
	}

	/* 悬浮时底部进度条展开 */
	.anime-card:hover .anime-progress-fill {
		width: 100% !important;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translate3d(0, 24px, 0);
		}
		to {
			opacity: 1;
			transform: translate3d(0, 0, 0);
		}
	}
</style>
