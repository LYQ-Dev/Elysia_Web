---
import { Icon } from "astro-icon/components";

export interface Props {
	id: string;
	title: string;
	description?: string;
	studio: string;
	cover?: string;
	status: "watching" | "completed" | "planned" | "dropped";
	rating?: number;
	totalEpisodes: number;
	watchedEpisodes?: number;
	year: string;
	genre?: string[];
	tags?: string[];
	link?: string;
}

const {
	id,
	title,
	description = "",
	studio,
	cover,
	status,
	rating = 5,
	totalEpisodes,
	watchedEpisodes = 0,
	year,
	genre = [],
	tags = [],
	link,
} = Astro.props as Props;
const detailLink = `/anime/${id}/`;

const getStatusInfo = (status: string) => {
	const statusMap: Record<string, { text: string; color: string; icon: string }> = {
		watching: { text: "追番中", color: "blue", icon: "material-symbols:play-circle" },
		completed: { text: "已完成", color: "green", icon: "material-symbols:check-circle" },
		planned: { text: "计划观看", color: "amber", icon: "material-symbols:schedule" },
		dropped: { text: "已弃番", color: "gray", icon: "material-symbols:cancel" },
	};
	return statusMap[status] || { text: status, color: "gray", icon: "material-symbols:play-circle" };
};

const statusInfo = getStatusInfo(status);
const colorMap: Record<string, string> = {
	blue: "bg-blue-500/10 text-blue-600 dark:text-blue-400 border-blue-600 dark:border-blue-400",
	green: "bg-green-500/10 text-green-600 dark:text-green-400 border-green-600 dark:border-green-400",
	amber: "bg-amber-500/10 text-amber-600 dark:text-amber-400 border-amber-600 dark:border-amber-400",
	gray: "bg-gray-500/10 text-gray-600 dark:text-gray-400 border-gray-600 dark:border-gray-400",
};

// 主题色映射（用于进度条）
const themeColorMap: Record<string, string> = {
	watching: "from-blue-500 to-blue-600",
	completed: "from-green-500 to-green-600",
	planned: "from-amber-500 to-amber-600",
	dropped: "from-gray-500 to-gray-600",
};

const watchProgress = totalEpisodes > 0 ? (watchedEpisodes / totalEpisodes * 100) : 0;
const descriptionText = description.trim() || `${year} · ${studio}`;
---

<a
	href={detailLink}
	class="anime-card card group relative flex"
	style={`--watch-progress: ${watchProgress.toFixed(2)};`}
>
	<div class="card-inner flex w-full rounded-[inherit] overflow-hidden">
		<!-- 左侧：封面容器 -->
		<div class="shrink-0 w-[126px] aspect-[10/16] relative bg-gradient-to-br from-black/5 to-black/10 overflow-hidden">
			{cover ? (
				<img
					src={cover}
					alt={title}
					class="w-full h-full object-cover transition-transform duration-500 ease-out"
					loading="lazy"
				/>
			) : (
				<div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-red-500/10 to-pink-500/20">
					<Icon name="material-symbols:movie" class="w-12 h-12 text-red-500/40" />
				</div>
			)}

			<!-- 评分徽章 -->
			{rating && (
				<div class="absolute top-2 right-2 flex items-center gap-0.5 bg-black/60 text-white px-2 py-1 rounded-md text-xs font-semibold">
					<Icon name="material-symbols:star-rounded" class="w-3 h-3" />
					<span>{rating}</span>
				</div>
			)}
		</div>

		<!-- 右侧：内容部分 -->
		<div class="card-details flex-1 px-5 py-4 border-l border-black/10">
			<div class="flex flex-col gap-2">
				<h3 class="text-title line-clamp-2">{title}</h3>
				<p class="text-body line-clamp-3">{descriptionText}</p>
			</div>

			<div class="flex flex-col gap-2.5">
				<div class="flex items-center gap-1 text-sm text-black/60 line-clamp-1">
					<span class="shrink-0">{year}</span>
					<span class="shrink-0">•</span>
					<span class="truncate">{studio}</span>
				</div>

				<div class="flex items-center gap-2 flex-wrap">
					<span class={`px-2 py-1 rounded text-xs font-medium flex items-center gap-1 ${colorMap[statusInfo.color]}`}>
						{statusInfo.text}
					</span>
					{genre && genre.length > 0 && (
						<span class="px-2 py-1 text-xs rounded bg-black/10 text-black/70 font-medium">
							{genre[0]}
						</span>
					)}
				</div>

				{totalEpisodes > 0 && (
					<div class="text-xs text-black/60 font-medium">
						{watchedEpisodes}/{totalEpisodes}
					</div>
				)}
			</div>
		</div>

		<!-- 底部进度条 -->
		<div class="anime-progress-bar absolute bottom-0 left-0 right-0 h-1.5 bg-black/8 overflow-hidden">
			<div
				class={`anime-progress-fill h-full bg-gradient-to-r ${themeColorMap[status]}`}
				style="width: 0%;"
			/>
		</div>
	</div>

	<span class="card-button">查看详情</span>
</a>

<style>
	.card {
		width: 100%;
		height: 212px;
		border-radius: 20px;
		background: #f5f5f5;
		position: relative;
		padding: 0;
		border: 2px solid #c3c6ce;
		transition: 0.5s ease-out;
		overflow: visible;
	}

	.anime-card {
		animation: fadeInUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
		opacity: 0;
	}

	.card-inner {
		height: 100%;
		background: #f5f5f5;
	}

	.card-details {
		color: black;
		height: 100%;
		gap: 0.5em;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
	}

	.card-button {
		transform: translate(-50%, 125%);
		width: 60%;
		max-width: 9.5rem;
		border-radius: 1rem;
		border: none;
		background-color: #008bf8;
		color: #fff;
		font-size: 0.95rem;
		font-weight: 700;
		padding: 0.5rem 1rem;
		position: absolute;
		left: 50%;
		bottom: 0;
		opacity: 0;
		transition: 0.3s ease-out;
		text-align: center;
		pointer-events: none;
		box-shadow: 0 8px 18px rgb(0 139 248 / 0.3);
	}

	.text-body {
		color: rgb(134 134 134);
		font-size: 0.88rem;
		line-height: 1.45;
	}

	.text-title {
		font-size: 1.05rem;
		font-weight: bold;
		line-height: 1.3;
		color: rgb(15 23 42 / 0.9);
	}

	.card:hover {
		border-color: #008bf8;
		box-shadow: 0 4px 18px 0 rgb(0 0 0 / 0.25);
	}

	.card:hover .card-button {
		transform: translate(-50%, 50%);
		opacity: 1;
	}

	.card:hover .text-title {
		color: #006ac6;
	}

	.card:hover img {
		transform: scale(1.05);
	}

	.card:hover .anime-progress-fill {
		width: calc(var(--watch-progress) * 1%);
	}

	@media (max-width: 768px) {
		.card {
			height: 198px;
		}

		.text-title {
			font-size: 0.95rem;
		}

		.text-body {
			font-size: 0.8rem;
		}

		.card-button {
			font-size: 0.85rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.card,
		.card-button,
		.anime-progress-fill,
		img {
			transition: none !important;
		}
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translate3d(0, 24px, 0);
		}
		to {
			opacity: 1;
			transform: translate3d(0, 0, 0);
		}
	}
</style>
