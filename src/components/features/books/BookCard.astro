---
import { Icon } from "astro-icon/components";

export interface Props {
	id: string;
	title: string;
	author: string;
	cover?: string;
	status: "reading" | "completed" | "planned" | "abandoned";
	rating?: number;
	category: string;
	tags?: string[];
	link?: string;
}

const { id, title, author, cover, status, rating = 5, category, tags = [], link } = Astro.props as Props;
const detailLink = `/books/${id}/`;

const getStatusText = (status: string) => {
	const statusMap: Record<string, { text: string; color: string; icon: string }> = {
		reading: { text: "阅读中", color: "blue", icon: "material-symbols:book-open" },
		completed: { text: "已完成", color: "green", icon: "material-symbols:check-circle" },
		planned: { text: "计划阅读", color: "amber", icon: "material-symbols:schedule" },
		abandoned: { text: "已放弃", color: "gray", icon: "material-symbols:cancel" },
	};
	return statusMap[status] || { text: status, color: "gray", icon: "material-symbols:book" };
};

const statusInfo = getStatusText(status);
const colorMap: Record<string, string> = {
	blue: "bg-blue-500/10 text-blue-600 dark:text-blue-400",
	green: "bg-green-500/10 text-green-600 dark:text-green-400",
	amber: "bg-amber-500/10 text-amber-600 dark:text-amber-400",
	gray: "bg-gray-500/10 text-gray-600 dark:text-gray-400",
};
---

<a href={detailLink} class="book-card group relative rounded-xl border border-black/10 dark:border-white/10 overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-1 block h-full">
	<!-- 封面图片 -->
	<div class="aspect-[3/4] overflow-hidden relative bg-gradient-to-br from-blue-500/5 to-indigo-500/10">
		{cover ? (
			<img
				src={cover}
				alt={title}
				class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
				loading="lazy"
			/>
		) : (
			<div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-blue-500/10 to-indigo-500/10">
				<Icon name="material-symbols:library-books" class="w-10 h-10 text-blue-500/30" />
			</div>
		)}
		<!-- 评分标记 -->
		{rating && (
			<div class="absolute top-3 right-3 flex items-center gap-1 bg-black/50 text-white px-2 py-1 rounded-lg text-xs font-medium backdrop-blur">
				<Icon name="material-symbols:star-rounded" class="w-3 h-3" />
				<span>{rating}</span>
			</div>
		)}
		<!-- 状态标记 -->
		<div class={`absolute bottom-3 left-3 flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-xs font-medium backdrop-blur ${colorMap[statusInfo.color]}`}>
			<Icon name={statusInfo.icon} class="w-3 h-3" />
			<span>{statusInfo.text}</span>
		</div>
		<div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
	</div>

	<!-- 内容区域 -->
	<div class="p-3">
		<!-- 标题和作者 -->
		<h3 class="text-sm font-bold text-black/90 dark:text-white/90 truncate group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors duration-200 mb-1">
			{title}
		</h3>
		<p class="text-sm text-black/60 dark:text-white/60 truncate mb-1">
			{author}
		</p>
		<p class="text-xs text-black/50 dark:text-white/50 truncate mb-3">
			{category}
		</p>

		<!-- 标签 -->
		{tags && tags.length > 0 && (
			<div class="flex flex-wrap gap-1.5 mb-3">
				{tags.slice(0, 2).map((tag) => (
					<span class="px-2 py-0.5 text-xs rounded-full bg-blue-500/10 text-blue-600 dark:text-blue-400 font-medium">
						{tag}
					</span>
				))}
				{tags.length > 2 && (
					<span class="px-2 py-0.5 text-xs rounded-full bg-black/5 dark:bg-white/5 text-black/50 dark:text-white/50 font-medium">
						+{tags.length - 2}
					</span>
				)}
			</div>
		)}

		<!-- 外部链接按钮 -->
		{link && (
			<button
				class="w-full flex items-center justify-center gap-2 px-3 py-2 rounded-lg text-sm font-medium bg-blue-500/10 text-blue-600 dark:text-blue-400 hover:bg-blue-500/20 transition-colors duration-200"
				onclick={`event.preventDefault(); window.open('${link}', '_blank');`}
			>
				<Icon name="material-symbols:open-in-new" class="w-3.5 h-3.5" />
				<span>查看</span>
			</button>
		)}
	</div>

	<!-- 悬停渐变背景 -->
	<div class="absolute inset-0 bg-gradient-to-br from-blue-500/5 to-indigo-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" />
</a>

<style>
	.book-card {
		animation: fadeInUp 0.5s ease-out forwards;
		opacity: 0;
	}

	.book-card.filtered-out {
		display: none;
	}
</style>
